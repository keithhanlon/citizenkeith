desc:SynthiAKS Analog Modular Synthesizer
version: 2.1
author: citizenkeith and Claude AI
about: Emulation of EMS Synthi AKS Synthesizer 
// @version 2.1
// @author citizenkeith
// @license GPL v3
// @provides
//   SynthiAKS - Modular Analog Synthesizer.jsfx
//   SynthiAKS.md
// @depends ../citizenkeith-ui-lib/citizenkeith-ui-lib.jsfx
// @about
//   Emulation of the EMS Synthi AKS modular synthesizer.
//   Oscillator with drift, 4-pole ladder filter, ADSR envelope, ring modulator,
//   Sample & Hold with selectable source routing, and MIDI input with pitch bend.
//   Custom GUI: hand-drawn horizontal sliders in color-coded sections.
// @changelog
//   v2.1
//     Subtitle "Analog Modular Synthesizer" changed to white
//     Slider fill changed from amber to off-white gray
//     Window height corrected to 928px — Envelope and MIDI sections were clipped
//   v2.0
//     Slider labels changed to white for readability
//     Added custom GUI with hand-drawn horizontal sliders and color-coded sections
//     Removed default REAPER slider GUI
//   v1.2
//     Added MIDI note on/off: triggers envelope, sets oscillator pitch
//     Added MIDI pitch bend (+/- 2 semitones)
//     Added S&H source selector: Noise / External / Oscillator
//     Added custom GUI: horizontal sliders, color-coded section headers
//   v1.1
//     Fixed ext_noinit (moved to options header)
//     Fixed ring modulator - now runs in @sample
//     Fixed VCA pin logic (unity when pin=0, envelope-controlled when pin>0)
//     Fixed Osc->Filter Cutoff pin now applied in cutoff calculation
//     Filter stability threshold raised from 2 to 10
//     Replaced inline 2*$pi with precomputed pi2 constant
//     Removed default GUI. Removed filter state from @serialize

options: no_meter ext_noinit

// SIGNAL SOURCES
slider1:0.7<0,1,0.01>-External Input Level
slider2:0.3<0,1,0.01>-Oscillator Level
slider3:440<20,2000,1>-Oscillator Frequency (manual / MIDI override)
slider4:0<0,3,1{Sawtooth,Triangle,Square,Sine}>-Oscillator Waveform
slider7:0.02<0,0.1,0.001>-Oscillator Drift

// FILTER
slider5:0.4<0,1,0.01>-Filter Cutoff
slider6:0.2<0,8,0.01>-Filter Resonance

// PIN MATRIX
slider10:0<-1,1,0.01>-Pin: Osc -> Filter Cutoff
slider11:0<-1,1,0.01>-Pin: Envelope -> Filter Cutoff
slider12:0<-1,1,0.01>-Pin: Envelope -> VCA (Amplitude)
slider13:0<0,1,0.01>-Pin: External -> Ring Modulator
slider14:0<0,1,0.01>-Pin: Osc -> Ring Modulator
slider15:40<5,200,1>-Ring Mod Frequency (Hz)
slider16:0.5<0,1,0.01>-Ring Mod Mix (Wet/Dry)

// SAMPLE & HOLD
slider30:0.3<0,1,0.01>-Noise Level
slider31:2<0.1,10,0.1>-S&H Clock Rate (Hz)
slider32:0<-1,1,0.01>-Pin: S&H -> Filter Cutoff
slider33:0<-1,1,0.01>-Pin: S&H -> Osc Frequency
slider34:0<-1,1,0.01>-Pin: S&H -> Ring Freq
slider35:0<0,2,1{Noise,External,Oscillator}>-S&H Source

// ENVELOPE
slider20:0.01<0.001,2,0.001>-Envelope Attack
slider21:0.1<0.001,2,0.001>-Envelope Decay
slider22:0.6<0,1,0.01>-Envelope Sustain
slider23:0.3<0.001,5,0.001>-Envelope Release
slider24:0<0,1,0.01>-Envelope Trigger (Manual)

@init

pi2 = 2 * $pi;
phase = 0; drift_phase = 0;
lp1 = lp2 = lp3 = lp4 = 0;
env_stage = 0; env_level = 0; env_trigger_prev = 0;
ring_mod_phase = 0;
sh_clock_phase = 0; sh_sample_value = 0; sh_clock_prev = 0;
sh_noise_seed = 12345; noise_val = 0; osc_raw = 0;
midi_note = -1; midi_freq = 440; midi_pitchbend = 0;
drag_slider = -1; drag_start_x = 0; drag_start_val = 0;

// GUI draw functions (must be defined in @init)

function draw_sec_hdr(sy, hr, hg, hb, title) local(tw, th) (
  gfx_r=hr; gfx_g=hg; gfx_b=hb; gfx_a=1;
  gfx_rect(GUI_SEC_X, sy, GUI_SEC_W, GUI_HDR_H);
  gfx_r=0.08; gfx_g=0.08; gfx_b=0.08; gfx_a=1;
  gfx_setfont(1, "Arial", 10, 'b');
  gfx_measurestr(title, tw, th);
  gfx_x = GUI_SEC_X + GUI_SEC_W/2 - tw/2;
  gfx_y = sy + GUI_HDR_H/2 - th/2;
  gfx_drawstr(title);
  gfx_r=0.28; gfx_g=0.28; gfx_b=0.32; gfx_a=1;
  gfx_rect(GUI_SEC_X, sy, GUI_SEC_W, 1);
  gfx_rect(GUI_SEC_X, sy + GUI_HDR_H, GUI_SEC_W, 1);
  sy + GUI_HDR_H;
);

function draw_hslider(sx, sy, sw, sh, val, lo, hi) local(norm, tx) (
  norm = max(0, min(1, (val - lo) / (hi - lo)));
  tx = sx + floor(norm * sw);
  // Track: dark recessed groove
  gfx_r=0.06; gfx_g=0.06; gfx_b=0.08; gfx_a=1;
  gfx_rect(sx, sy + sh/2 - 4, sw, 8);
  // Filled portion: bright amber glow
  gfx_r=0.62; gfx_g=0.62; gfx_b=0.65; gfx_a=1;
  gfx_rect(sx, sy + sh/2 - 4, floor(norm * sw), 8);
  // Track border
  gfx_r=0.35; gfx_g=0.35; gfx_b=0.40; gfx_a=1;
  gfx_rect(sx, sy + sh/2 - 4, sw, 1);
  gfx_rect(sx, sy + sh/2 + 3, sw, 1);
  gfx_rect(sx, sy + sh/2 - 4, 1, 8);
  gfx_rect(sx + sw, sy + sh/2 - 4, 1, 9);
  // Thumb: bright white-gray, tall and visible
  gfx_r=0.90; gfx_g=0.90; gfx_b=0.92; gfx_a=1;
  gfx_rect(tx - 5, sy + sh/2 - 9, 10, 18);
  // Thumb shadow edges
  gfx_r=0.25; gfx_g=0.25; gfx_b=0.28; gfx_a=1;
  gfx_rect(tx - 5, sy + sh/2 - 9, 10, 1);
  gfx_rect(tx - 5, sy + sh/2 + 8, 10, 1);
  gfx_rect(tx - 5, sy + sh/2 - 9, 1, 18);
  gfx_rect(tx + 4, sy + sh/2 - 9, 1, 18);
  // Thumb center line
  gfx_r=0.50; gfx_g=0.50; gfx_b=0.54; gfx_a=1;
  gfx_rect(tx - 1, sy + sh/2 - 5, 2, 10);
);

function draw_row(sy, lbl, val_str) local(lw, lh) (
  gfx_r=0.12; gfx_g=0.12; gfx_b=0.14; gfx_a=1;
  gfx_rect(GUI_SEC_X, sy, GUI_SEC_W, GUI_ROW_H);
  gfx_r=0.20; gfx_g=0.20; gfx_b=0.22; gfx_a=1;
  gfx_rect(GUI_SEC_X, sy + GUI_ROW_H - 1, GUI_SEC_W, 1);
  gfx_r=0.92; gfx_g=0.92; gfx_b=0.94; gfx_a=1;
  gfx_setfont(1, "Arial", 10);
  gfx_measurestr(lbl, lw, lh);
  gfx_x = GUI_SEC_X + GUI_LBL_W - lw - 6;
  gfx_y = sy + GUI_ROW_H/2 - lh/2;
  gfx_drawstr(lbl);
  gfx_r=1.0; gfx_g=0.82; gfx_b=0.44; gfx_a=1;
  gfx_measurestr(val_str, lw, lh);
  gfx_x = GUI_VAL_X + GUI_VAL_W - lw - 4;
  gfx_y = sy + GUI_ROW_H/2 - lh/2;
  gfx_drawstr(val_str);
  sy + GUI_ROW_H;
);

function process_slider(sy, val, lo, hi) local(new_val, in_zone, mx_rel) (
  in_zone = (mouse_x >= GUI_SLD_X && mouse_x <= GUI_SLD_X + GUI_SLD_W &&
             mouse_y >= sy && mouse_y < sy + GUI_ROW_H);
  mouse_btn && in_zone && drag_slider < 0 ? (
    drag_slider = row_idx;
  );
  drag_slider == row_idx ? (
    mx_rel = (mouse_x - GUI_SLD_X) / GUI_SLD_W;
    val = max(lo, min(hi, lo + mx_rel * (hi - lo)));
  );
  row_idx += 1;
  val;
);

@serialize
file_var(0, env_stage);
file_var(0, env_level);
file_var(0, phase);
file_var(0, drift_phase);
file_var(0, sh_clock_phase);
file_var(0, sh_sample_value);
file_var(0, sh_noise_seed);

@block

while (midirecv(mpos, msg1, msg2, msg3)) (
  status = msg1 & 0xF0;
  status == 0x90 && msg3 > 0 ? (
    midi_note = msg2;
    midi_freq = 440.0 * pow(2.0, (midi_note - 69) / 12.0);
    env_stage = 1;
  ) : (status == 0x80 || (status == 0x90 && msg3 == 0)) ? (
    msg2 == midi_note ? (midi_note = -1; env_stage = 4;);
  ) : status == 0xE0 ? (
    bend_raw = msg2 | (msg3 << 7);
    midi_pitchbend = (bend_raw - 8192) / 8192.0 * 2.0;
  );
  midisend(mpos, msg1, msg2, msg3);
);

@sample

input = (spl0 + spl1) * 0.5;
sh_noise_seed = (sh_noise_seed * 1103515245 + 12345) & 0x7fffffff;
noise_val = (sh_noise_seed / 0x7fffffff) * 2 - 1;
noise_output = noise_val * slider30;

sh_clock_phase += slider31 * pi2 / srate;
sh_clock_phase >= pi2 ? sh_clock_phase -= pi2;
sh_clock_signal = sin(sh_clock_phase);
sh_clock_trigger = (sh_clock_signal > 0) && (sh_clock_prev <= 0);
sh_clock_prev = sh_clock_signal;
sh_clock_trigger ? (
  slider35 < 0.5 ? sh_sample_value = noise_val :
  slider35 < 1.5 ? sh_sample_value = input :
                   sh_sample_value = osc_raw;
);
sh_output = sh_sample_value;

base_freq = midi_note >= 0 ? midi_freq : slider3;
base_freq *= pow(2.0, midi_pitchbend / 12.0);
drift_phase += 0.1 / srate;
drift_phase >= 1 ? drift_phase -= 1;
drift_offset = sin(drift_phase * pi2) * slider7 * base_freq;
osc_freq = max(20, min(2000, base_freq + (sh_output * slider33 * 200) + drift_offset));
phase += osc_freq * pi2 / srate;
phase >= pi2 ? phase -= pi2;

slider4 < 0.5 ? (
  osc_raw = (phase / $pi) - 1;
) : slider4 < 1.5 ? (
  phase < $pi ? osc_raw = (phase / $pi * 2) - 1 : osc_raw = 3 - (phase / $pi * 2);
) : slider4 < 2.5 ? (
  osc_raw = phase < $pi ? -0.8 : 0.8;
) : (
  osc_raw = sin(phase);
);
osc = osc_raw * slider2 * 0.9;

slider24 > 0.5 && env_trigger_prev <= 0.5 ? env_stage = 1;
env_trigger_prev = slider24;
env_stage == 1 ? (
  env_level += 1.0 / (slider20 * srate);
  env_level >= 1.0 ? (env_level = 1.0; env_stage = 2;);
) : env_stage == 2 ? (
  env_level -= (1.0 - slider22) / (slider21 * srate);
  env_level <= slider22 ? (env_level = slider22; env_stage = 3;);
) : env_stage == 3 ? (
  env_level = slider22;
  (slider24 <= 0.5 && midi_note < 0) ? env_stage = 4;
) : env_stage == 4 ? (
  env_level -= env_level / (slider23 * srate);
  env_level <= 0.00001 ? (env_level = 0; env_stage = 0;);
);
envelope = max(0, min(1, env_level));

slider12 == 0 ? vca_mod = 1.0 : vca_mod = max(0, min(1, envelope * slider12 + (1.0 - slider12)));
mixed_signal = ((input * slider1) + osc + noise_output) * vca_mod;

ring_freq = max(5, min(500, slider15 + (sh_output * slider34 * 100)));
ring_mod_phase += ring_freq * pi2 / srate;
ring_mod_phase >= pi2 ? ring_mod_phase -= pi2;
ring_carrier = sin(ring_mod_phase);
ring_input = (input * slider13) + (osc * slider14);
mixed_signal = mixed_signal * (1.0 - slider16) + ring_input * ring_carrier * slider16;

final_cutoff = max(0, min(1, slider5 + (osc_raw * slider10 * 0.3) + (envelope * slider11 * 0.3) + (sh_output * slider32 * 0.3)));
filter_freq = max(0.001, min(0.45, final_cutoff * final_cutoff * 0.4));
filter_q = slider6 * 1.5;
filter_g = tan(filter_freq * $pi);
(abs(lp1) > 10 || abs(lp2) > 10 || abs(lp3) > 10 || abs(lp4) > 10) ? lp1 = lp2 = lp3 = lp4 = 0;
filter_feedback = lp4 * filter_q;
lp1 += filter_g * ((mixed_signal - filter_feedback) - lp1);
lp2 += filter_g * (lp1 - lp2);
lp3 += filter_g * (lp2 - lp3);
lp4 += filter_g * (lp3 - lp4);
lp4 > 0.8 ? lp4 = 0.8 : lp4 < -0.8 ? lp4 = -0.8;
spl0 = lp4; spl1 = lp4;

@gfx 560 928

// Layout constants (set each frame so they're always fresh)
GUI_PAD   = 8;
GUI_LBL_W = 148;
GUI_VAL_W = 68;
GUI_ROW_H = 28;
GUI_HDR_H = 22;
GUI_SEC_X = GUI_PAD;
GUI_SEC_W = gfx_w - GUI_PAD * 2;
GUI_SLD_W = GUI_SEC_W - GUI_LBL_W - GUI_VAL_W - GUI_PAD * 2;
GUI_SLD_X = GUI_SEC_X + GUI_LBL_W;
GUI_VAL_X = GUI_SLD_X + GUI_SLD_W + GUI_PAD;

// Background
gfx_r=0.14; gfx_g=0.14; gfx_b=0.16; gfx_a=1;
gfx_rect(0, 0, gfx_w, gfx_h);

// Title
gfx_r=0.78; gfx_g=0.78; gfx_b=0.82; gfx_a=1;
gfx_setfont(1, "Trebuchet MS", 14, 'b');
gfx_x=12; gfx_y=10; gfx_drawstr("SYNTHIAKS");
gfx_r=1.0; gfx_g=1.0; gfx_b=1.0; gfx_a=1;
gfx_setfont(1, "Trebuchet MS", 10);
gfx_x=116; gfx_y=13; gfx_drawstr("Analog Modular Synthesizer");

mouse_btn = mouse_cap & 1;
mouse_btn == 0 ? drag_slider = -1;
row_idx = 0;
cur_y = 32;

// SIGNAL SOURCES
cur_y = draw_sec_hdr(cur_y, 0.82, 0.18, 0.14, "SIGNAL SOURCES");
slider1 = process_slider(cur_y, slider1, 0, 1);
sprintf(#v, "%.2f", slider1);
cur_y = draw_row(cur_y, "Ext Input Level", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider1, 0, 1);

slider2 = process_slider(cur_y, slider2, 0, 1);
sprintf(#v, "%.2f", slider2);
cur_y = draw_row(cur_y, "Osc Level", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider2, 0, 1);

slider3 = process_slider(cur_y, slider3, 20, 2000);
sprintf(#v, "%.0f Hz", slider3);
cur_y = draw_row(cur_y, "Osc Frequency", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider3, 20, 2000);

slider4 = process_slider(cur_y, slider4, 0, 3);
slider4 < 0.5 ? strcpy(#v,"Sawtooth") : slider4 < 1.5 ? strcpy(#v,"Triangle") :
slider4 < 2.5 ? strcpy(#v,"Square") : strcpy(#v,"Sine");
cur_y = draw_row(cur_y, "Osc Waveform", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider4, 0, 3);

slider7 = process_slider(cur_y, slider7, 0, 0.1);
sprintf(#v, "%.3f", slider7);
cur_y = draw_row(cur_y, "Osc Drift", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider7, 0, 0.1);

cur_y += 4;

// FILTER
cur_y = draw_sec_hdr(cur_y, 0.8, 0.55, 0.08, "FILTER");
slider5 = process_slider(cur_y, slider5, 0, 1);
sprintf(#v, "%.2f", slider5);
cur_y = draw_row(cur_y, "Cutoff", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider5, 0, 1);

slider6 = process_slider(cur_y, slider6, 0, 8);
sprintf(#v, "%.2f", slider6);
cur_y = draw_row(cur_y, "Resonance", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider6, 0, 8);

cur_y += 4;

// PIN MATRIX
cur_y = draw_sec_hdr(cur_y, 0.18, 0.45, 0.82, "PIN MATRIX");
slider10 = process_slider(cur_y, slider10, -1, 1);
sprintf(#v, "%.2f", slider10);
cur_y = draw_row(cur_y, "Osc -> Filter Cutoff", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider10, -1, 1);

slider11 = process_slider(cur_y, slider11, -1, 1);
sprintf(#v, "%.2f", slider11);
cur_y = draw_row(cur_y, "Env -> Filter Cutoff", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider11, -1, 1);

slider12 = process_slider(cur_y, slider12, -1, 1);
sprintf(#v, "%.2f", slider12);
cur_y = draw_row(cur_y, "Env -> VCA", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider12, -1, 1);

slider13 = process_slider(cur_y, slider13, 0, 1);
sprintf(#v, "%.2f", slider13);
cur_y = draw_row(cur_y, "Ext -> Ring Mod", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider13, 0, 1);

slider14 = process_slider(cur_y, slider14, 0, 1);
sprintf(#v, "%.2f", slider14);
cur_y = draw_row(cur_y, "Osc -> Ring Mod", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider14, 0, 1);

slider15 = process_slider(cur_y, slider15, 5, 200);
sprintf(#v, "%.0f Hz", slider15);
cur_y = draw_row(cur_y, "Ring Mod Freq", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider15, 5, 200);

slider16 = process_slider(cur_y, slider16, 0, 1);
sprintf(#v, "%.2f", slider16);
cur_y = draw_row(cur_y, "Ring Mod Mix", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider16, 0, 1);

cur_y += 4;

// SAMPLE & HOLD
cur_y = draw_sec_hdr(cur_y, 0.52, 0.22, 0.78, "SAMPLE & HOLD");
slider30 = process_slider(cur_y, slider30, 0, 1);
sprintf(#v, "%.2f", slider30);
cur_y = draw_row(cur_y, "Noise Level", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider30, 0, 1);

slider31 = process_slider(cur_y, slider31, 0.1, 10);
sprintf(#v, "%.1f Hz", slider31);
cur_y = draw_row(cur_y, "S&H Clock Rate", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider31, 0.1, 10);

slider35 = process_slider(cur_y, slider35, 0, 2);
slider35 < 0.5 ? strcpy(#v,"Noise") : slider35 < 1.5 ? strcpy(#v,"External") : strcpy(#v,"Oscillator");
cur_y = draw_row(cur_y, "S&H Source", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider35, 0, 2);

slider32 = process_slider(cur_y, slider32, -1, 1);
sprintf(#v, "%.2f", slider32);
cur_y = draw_row(cur_y, "S&H -> Filter Cutoff", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider32, -1, 1);

slider33 = process_slider(cur_y, slider33, -1, 1);
sprintf(#v, "%.2f", slider33);
cur_y = draw_row(cur_y, "S&H -> Osc Freq", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider33, -1, 1);

slider34 = process_slider(cur_y, slider34, -1, 1);
sprintf(#v, "%.2f", slider34);
cur_y = draw_row(cur_y, "S&H -> Ring Freq", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider34, -1, 1);

cur_y += 4;

// ENVELOPE
cur_y = draw_sec_hdr(cur_y, 0.16, 0.68, 0.28, "ENVELOPE");
slider20 = process_slider(cur_y, slider20, 0.001, 2);
sprintf(#v, "%.3f s", slider20);
cur_y = draw_row(cur_y, "Attack", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider20, 0.001, 2);

slider21 = process_slider(cur_y, slider21, 0.001, 2);
sprintf(#v, "%.3f s", slider21);
cur_y = draw_row(cur_y, "Decay", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider21, 0.001, 2);

slider22 = process_slider(cur_y, slider22, 0, 1);
sprintf(#v, "%.2f", slider22);
cur_y = draw_row(cur_y, "Sustain", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider22, 0, 1);

slider23 = process_slider(cur_y, slider23, 0.001, 5);
sprintf(#v, "%.3f s", slider23);
cur_y = draw_row(cur_y, "Release", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider23, 0.001, 5);

slider24 = process_slider(cur_y, slider24, 0, 1);
slider24 > 0.5 ? strcpy(#v,"ON") : strcpy(#v,"OFF");
cur_y = draw_row(cur_y, "Manual Trigger", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider24, 0, 1);

cur_y += 4;

// MIDI STATUS
cur_y = draw_sec_hdr(cur_y, 0.12, 0.62, 0.68, "MIDI");
gfx_r=0.12; gfx_g=0.12; gfx_b=0.14; gfx_a=1;
gfx_rect(GUI_SEC_X, cur_y, GUI_SEC_W, GUI_ROW_H + 4);
midi_note >= 0 ? (
  sprintf(#midi_disp, "Note %d  %.1f Hz", midi_note, midi_freq);
) : (
  sprintf(#midi_disp, "No note held  (%.0f Hz manual)", slider3);
);
gfx_r=1.0; gfx_g=0.82; gfx_b=0.44; gfx_a=1;
gfx_setfont(1, "Arial", 10);
gfx_x=GUI_SEC_X+8; gfx_y=cur_y+5; gfx_drawstr(#midi_disp);
sprintf(#pb_str, "Pitch Bend: %+.2f semitones", midi_pitchbend);
gfx_r=0.55; gfx_g=0.55; gfx_b=0.60; gfx_a=1;
