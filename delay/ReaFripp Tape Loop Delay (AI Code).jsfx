desc: ReaFripp Tape Loop Delay
version: 2.1
author: citizenkeith - Claude AI
about:
  Frippertronics-inspired tape loop delay.
  Variable loop length, feedback, damping, saturation, and wow/flutter modulation.
  Supports tempo sync with seven time divisions. 

// ReaPack metadata
// @version 2.1
// @author citizenkeith
// @license GPL v3
// @about
//   Frippertronics-inspired tape loop delay with variable loop length,
//   feedback, HF damping, tape saturation, wow/flutter modulation,
//   and tempo sync.
// @changelog
//   v2.1
//     Standardized section header colors: Delay=red, Tempo Sync=blue, Tape Effects=amber, Output=green
//   v2.0
//     New "standard" GUI
//     DELAY section: Loop, Feedback, Damping knobs; Loop greys out when sync active
//     TEMPO SYNC section: Tycho-style scrolling division box + SYNC button, purple header
//     TAPE EFFECTS section: Sat Mode switch, Saturation, W&F knobs
//     OUTPUT section: Mix (%), LF Mono (Hz / OFF)
//     Added LF Mono slider (0-300Hz): first-order crossover sums low band to center
//     Renamed Mono Bass to LF Mono for consistency with Fidelio
//     Restored REAPER I/O meters (removed no_meter)
//     Added @block tempo tracking: loop size now follows host tempo changes live
//     Pre-calculated mix_inv in @slider; two_pi constant in @init
//     Removed bespoke v1 GUI (~400 lines) and all associated dead state variables
//     Removed needs_recalc block from @sample (duplicate of @slider logic)
//     Moved wow/flutter increments to @init (no slider dependency)
//     Replaced Taylor series sin approximation with real sin() (invalid at large angles)
//     Pre-calculated damping_coeff_inv in @slider
//     Inlined interp_factor
//   v1.0
//     Initial release

import citizenkeith-ui-lib.jsfx-inc

slider1:4<0.1,10,0.1>-Loop Length (seconds)
slider2:0.8<0,1,0.01>-Feedback
slider3:0.5<0,1,0.01>-Wet/Dry Mix
slider4:0.0<0,1,0.01>-High-Frequency Damping
slider5:0<0,1,0.01>-Saturation
slider6:1<0,1,1{Soft Clipping,Tape Saturation}>-Saturation Mode
slider7:0<0,1,0.01>-Wow/Flutter
slider8:0<0,1,1{Off,On}>-Tempo Sync
slider9:2<0,6,1{1/4,1/2,1,2,4,8,16}>-Time Division
slider10:0<0,300,1>-LF Mono (Hz)

options:gfx_hz=60

@init
max_loop_seconds = 10;
safety_margin = 1.1;
max_buffer_size = max((srate * max_loop_seconds * safety_margin) | 0, 44100);

buffer_l = 0;
buffer_r = max_buffer_size;

memset(buffer_l, 0, max_buffer_size);
memset(buffer_r, 0, max_buffer_size);

write_pos = 0;
loop_size = max(1, srate * slider1);

// Low-pass filter state
lp_state_l = 0;
lp_state_r = 0;

// Mono bass crossover filter state (first-order LP/HP pair)
mb_lp_l = 0;
mb_lp_r = 0;

ui_setup(max_buffer_size * 2 + 64);

// ============================================================
// GFX HELPER FUNCTIONS
// ============================================================

function draw_section_box(bx, by, bw, bh, hr, hg, hb, header_text)
local(tw, th)
(
  gfx_r = 0.13; gfx_g = 0.13; gfx_b = 0.15; gfx_a = 1;
  gfx_rect(bx, by, bw, bh);
  gfx_r = hr; gfx_g = hg; gfx_b = hb; gfx_a = 1;
  gfx_rect(bx, by, bw, 22);
  gfx_r = 0.08; gfx_g = 0.08; gfx_b = 0.08; gfx_a = 1;
  gfx_setfont(1, "Arial", 11, 'b');
  gfx_measurestr(header_text, tw, th);
  gfx_x = bx + bw/2 - tw/2;
  gfx_y = by + 11 - th/2;
  gfx_drawstr(header_text);
  gfx_r = 0.30; gfx_g = 0.30; gfx_b = 0.34; gfx_a = 1;
  gfx_rect(bx,      by,      bw, 1);
  gfx_rect(bx,      by + bh, bw, 1);
  gfx_rect(bx,      by,      1,  bh);
  gfx_rect(bx + bw, by,      1,  bh + 1);
);

function draw_label_at(lx, ly)
local(lw, lh)
(
  gfx_r = 0.68; gfx_g = 0.68; gfx_b = 0.72; gfx_a = 1;
  gfx_setfont(1, "Arial", 10);
  gfx_measurestr(#lbl, lw, lh);
  gfx_x = lx - lw/2;
  gfx_y = ly;
  gfx_drawstr(#lbl);
);

function draw_value_at(vx, vy)
local(vw, vh)
(
  gfx_r = 1.0; gfx_g = 0.82; gfx_b = 0.44; gfx_a = 1;
  gfx_setfont(1, "Arial", 10);
  gfx_measurestr(#val, vw, vh);
  gfx_x = vx - vw/2;
  gfx_y = vy;
  gfx_drawstr(#val);
);

function draw_switch_label(cx, ly, label)
local(lw, lh)
(
  gfx_r = 1.0; gfx_g = 1.0; gfx_b = 1.0; gfx_a = 1;
  gfx_setfont(1, "Arial", 10);
  gfx_measurestr(label, lw, lh);
  gfx_x = cx - lw/2;
  gfx_y = ly;
  gfx_drawstr(label);
);

function check_dbl_click()
local(mx, my, now, dt)
(
  mx  = mouse_x;
  my  = mouse_y;
  now = time_precise();
  (mouse_cap & 1) && !(mouse_cap_last & 1) ? (
    dt = now - dbl_click_time;
    (dt < 0.4) && (dt > 0.05) && (abs(mx - dbl_click_x) < 8) && (abs(my - dbl_click_y) < 8) ? (
      dbl_click_fired = 1;
      dbl_click_cx    = mx;
      dbl_click_cy    = my;
    ) : (
      dbl_click_fired = 0;
    );
    dbl_click_time = now;
    dbl_click_x    = mx;
    dbl_click_y    = my;
  ) : (
    dbl_click_fired = 0;
  );
);

function dbl_click_in_rect(rx, ry, rw, rh)
(
  dbl_click_fired &&
  (dbl_click_cx >= rx) && (dbl_click_cx < rx + rw) &&
  (dbl_click_cy >= ry) && (dbl_click_cy < ry + rh)
);

// Wow/flutter phase tracking
wow_phase = 0;
flutter_phase = 0;

// Wow/flutter increments are fixed — only depend on srate
wow_increment     = 0.5  / srate;   // ~0.5 Hz wow
flutter_increment = 12.0 / srate;   // ~12 Hz flutter

two_pi = 2 * $pi;

@slider
tempo_sync    = slider8;
time_division = slider9;

tempo_sync ? (
    current_tempo = tempo;
    current_tempo <= 0 ? current_tempo = 120;
    beat_length = 60 / current_tempo;

    time_division == 0 ? loop_length_seconds = beat_length;
    time_division == 1 ? loop_length_seconds = beat_length * 2;
    time_division == 2 ? loop_length_seconds = beat_length * 4;
    time_division == 3 ? loop_length_seconds = beat_length * 8;
    time_division == 4 ? loop_length_seconds = beat_length * 16;
    time_division == 5 ? loop_length_seconds = beat_length * 32;
    time_division == 6 ? loop_length_seconds = beat_length * 64;
) : (
    loop_length_seconds = slider1;
);

loop_size    = max(1, min(max_buffer_size - 1, srate * loop_length_seconds));
feedback     = slider2;
mix          = slider3;
mix_inv      = 1 - mix;
damping      = slider4;
saturation   = slider5;
saturation_mode = slider6;
wow_flutter  = slider7;

// Damping filter coefficient — pre-calculate both coeff and its complement
cutoff_freq      = 20000 - damping * 19000;
damping_coeff     = exp(-2 * $pi * cutoff_freq / srate);
damping_coeff_inv = 1 - damping_coeff;

// Saturation pre-calculations
saturation > 0 ? (
    saturation_mode ? (
        saturation_drive = 1 + saturation * 10;
        saturation_scale = 1 / (saturation_drive * 0.5);
    ) : (
        saturation_drive = 1 + saturation * 5;
        saturation_scale = 1 / (saturation_drive * 0.7);
    );
);

// Mono bass crossover — first-order one-pole LP coefficient
// At 0 Hz the filter is bypassed entirely
mono_bass_freq = slider10;
mono_bass_freq > 0 ? (
    mb_coeff     = exp(-2 * $pi * mono_bass_freq / srate);
    mb_coeff_inv = 1 - mb_coeff;
);

@block
// Live tempo tracking — update loop size when host tempo changes during sync
tempo_sync ? (
    current_tempo = tempo;
    current_tempo <= 0 ? current_tempo = 120;
    beat_length = 60 / current_tempo;
    time_division == 0 ? new_loop_seconds = beat_length :
    time_division == 1 ? new_loop_seconds = beat_length * 2 :
    time_division == 2 ? new_loop_seconds = beat_length * 4 :
    time_division == 3 ? new_loop_seconds = beat_length * 8 :
    time_division == 4 ? new_loop_seconds = beat_length * 16 :
    time_division == 5 ? new_loop_seconds = beat_length * 32 :
                         new_loop_seconds = beat_length * 64;
    abs(new_loop_seconds - loop_length_seconds) > 0.001 ? (
        loop_length_seconds = new_loop_seconds;
        loop_size = max(1, min(max_buffer_size - 1, srate * loop_length_seconds));
    );
);

@sample
// Keep write position in bounds
write_pos >= loop_size ? write_pos = 0;

// Wow and flutter modulation
wow_flutter > 0.001 ? (
    wow_phase     += wow_increment;
    wow_phase     >= 1 ? wow_phase     -= 1;
    flutter_phase += flutter_increment;
    flutter_phase >= 1 ? flutter_phase -= 1;

    // Real sin() — Taylor series is inaccurate at large phase angles
    wow_mod     = 0.000008 * sin(two_pi * wow_phase);
    flutter_mod = 0.000003 * sin(two_pi * flutter_phase);

    total_modulation = wow_flutter * (wow_mod + flutter_mod);
) : (
    total_modulation = 0;
);

// Read position with modulation
read_offset = loop_size * (1 + total_modulation);
read_pos    = write_pos - read_offset;
read_pos < 0 ? read_pos += loop_size;
read_pos >= loop_size ? read_pos -= loop_size;

// Linear interpolation
read_pos_int  = read_pos | 0;
read_pos_frac = read_pos - read_pos_int;
read_pos_next = read_pos_int + 1;
read_pos_next >= loop_size ? read_pos_next = 0;

loop_sample_l = buffer_l[read_pos_int] * (1 - read_pos_frac) + buffer_l[read_pos_next] * read_pos_frac;
loop_sample_r = buffer_r[read_pos_int] * (1 - read_pos_frac) + buffer_r[read_pos_next] * read_pos_frac;

// HF damping — uses pre-calculated coeff and inv
lp_state_l = lp_state_l * damping_coeff + loop_sample_l * damping_coeff_inv;
lp_state_r = lp_state_r * damping_coeff + loop_sample_r * damping_coeff_inv;
loop_sample_l = lp_state_l;
loop_sample_r = lp_state_r;

// Saturation
saturation > 0.001 ? (
    saturation_mode ? (
        // Tape saturation (asymmetric)
        loop_sample_l *= saturation_drive;
        loop_sample_r *= saturation_drive;
        loop_sample_l = loop_sample_l > 0 ?
            loop_sample_l / (1 + loop_sample_l) :
            loop_sample_l / (1 - loop_sample_l * 0.7);
        loop_sample_r = loop_sample_r > 0 ?
            loop_sample_r / (1 + loop_sample_r) :
            loop_sample_r / (1 - loop_sample_r * 0.7);
        loop_sample_l *= saturation_scale;
        loop_sample_r *= saturation_scale;
    ) : (
        // Soft clipping (symmetric, tanh approximation)
        loop_sample_l *= saturation_drive;
        loop_sample_r *= saturation_drive;
        abs_l = abs(loop_sample_l);
        abs_r = abs(loop_sample_r);
        loop_sample_l = abs_l > 1 ? sign(loop_sample_l) : loop_sample_l * (1 - abs_l * abs_l / 3);
        loop_sample_r = abs_r > 1 ? sign(loop_sample_r) : loop_sample_r * (1 - abs_r * abs_r / 3);
        loop_sample_l *= saturation_scale;
        loop_sample_r *= saturation_scale;
    );
);

// Write input + feedback into buffer
buffer_l[write_pos] = spl0 + loop_sample_l * feedback;
buffer_r[write_pos] = spl1 + loop_sample_r * feedback;
write_pos += 1;

// Output mix
spl0 = spl0 * mix_inv + loop_sample_l * mix;
spl1 = spl1 * mix_inv + loop_sample_r * mix;

// Mono bass — split into LP (mono-summed) and HP (stereo), recombine
mono_bass_freq > 0 ? (
    // One-pole lowpass extracts the low band
    mb_lp_l = mb_lp_l * mb_coeff + spl0 * mb_coeff_inv;
    mb_lp_r = mb_lp_r * mb_coeff + spl1 * mb_coeff_inv;

    // Mono-sum the low band, highpass = original - lowpass
    mb_mono  = (mb_lp_l + mb_lp_r) * 0.5;
    spl0 = mb_mono + (spl0 - mb_lp_l);
    spl1 = mb_mono + (spl1 - mb_lp_r);
);

@gfx 520 364

control_start("main", "tron");

gfx_r = 0.14; gfx_g = 0.14; gfx_b = 0.16; gfx_a = 1;
gfx_rect(0, 0, gfx_w, gfx_h);

check_dbl_click();

// ============================================================
// LAYOUT CONSTANTS
// ============================================================

pad    = 8;
gap    = 8;
kr     = 22;

row1_y  = 38;
row1_h  = 130;
row1_cy = row1_y + 22 + 60;   // 120

row2_y  = row1_y + row1_h + gap;
row2_h  = 180;
row2_cy = row2_y + 22 + 68;

// Row 1: DELAY | TEMPO SYNC
delay_w  = 310;
sync_w   = gfx_w - pad*2 - delay_w - gap;
delay_x  = pad;
sync_x   = pad + delay_w + gap;

dl_k1 = delay_x + delay_w * 0.22;   // Loop
dl_k2 = delay_x + delay_w * 0.50;   // Feedback
dl_k3 = delay_x + delay_w * 0.78;   // Damping

// Sync widget centered in TEMPO SYNC section
sync_ctr_x  = sync_x + sync_w * 0.5;
sync_box_w  = 52;
sync_box_h  = 34;
sync_btn_w  = 32;
sync_gap    = 5;
sync_box_x  = sync_ctr_x - (sync_box_w + sync_gap + sync_btn_w) / 2;
sync_btn_x  = sync_box_x + sync_box_w + sync_gap;
sync_box_y  = row1_cy - sync_box_h / 2;
sync_lbl_y  = sync_box_y - 15;
arrow_h     = 11;

// Row 2: TAPE EFFECTS | OUTPUT
tape_w  = 300;
out_w   = gfx_w - pad*2 - tape_w - gap;
tape_x  = pad;
out_x   = tape_x + tape_w + gap;

tape_sw = tape_x + tape_w * 0.22;
tape_k1 = tape_x + tape_w * 0.55;
tape_k2 = tape_x + tape_w * 0.82;

out_k1  = out_x + out_w * 0.33;
out_k2  = out_x + out_w * 0.67;

// ============================================================
// PLUGIN TITLE
// ============================================================
gfx_r = 0.78; gfx_g = 0.78; gfx_b = 0.82; gfx_a = 1;
gfx_setfont(1, "Trebuchet MS", 14, 'b');
gfx_x = 12; gfx_y = 8;
gfx_drawstr("REAFRIPP TAPE LOOP DELAY");

// ============================================================
// ROW 1A — DELAY (red)
// ============================================================
draw_section_box(delay_x, row1_y, delay_w, row1_h, 0.82, 0.22, 0.14, "DELAY");

// LOOP LENGTH (greyed when sync on)
slider8 ? (
  norm_loop = (loop_length_seconds - 0.1) / 9.9;
  start_a = $pi * 0.75; end_a = $pi * 2.25;
  angle = start_a + norm_loop * (end_a - start_a);
  gfx_r = 0.16; gfx_g = 0.16; gfx_b = 0.18; gfx_a = 1;
  gfx_circle(dl_k1, row1_cy, kr - 2, 1, 1);
  track_r = kr - 5;
  j = 0; loop(floor(norm_loop * 270),
    a = start_a + j * $pi / 180;
    gfx_r = 0.28; gfx_g = 0.30; gfx_b = 0.36; gfx_a = 1;
    gfx_circle(dl_k1 + cos(a)*track_r, row1_cy + sin(a)*track_r, 1.2, 1, 1);
    j += 1;
  );
  px = dl_k1 + cos(angle) * (kr * 0.45);
  py = row1_cy + sin(angle) * (kr * 0.45);
  gfx_r = 0.40; gfx_g = 0.40; gfx_b = 0.44; gfx_a = 1;
  gfx_circle(px, py, 2.5, 1, 1);
  gfx_r = 0.45; gfx_g = 0.45; gfx_b = 0.50; gfx_a = 1;
  gfx_setfont(1, "Arial", 10);
  gfx_measurestr("LOOP", lw, lh);
  gfx_x = dl_k1 - lw/2; gfx_y = row1_cy - kr - 14; gfx_drawstr("LOOP");
  gfx_r = 0.60; gfx_g = 0.50; gfx_b = 0.30; gfx_a = 1;
  sprintf(#val, "%.2f s", loop_length_seconds);
  gfx_measurestr(#val, lw, lh);
  gfx_x = dl_k1 - lw/2; gfx_y = row1_cy + kr + 4; gfx_drawstr(#val);
) : (
  ui_push_rect(dl_k1-kr, row1_cy-kr, kr*2, kr*2);
    slider1 = control_dial(slider1, 0.1, 10, 0);
    slider_automate(slider1);
  ui_pop();
  dbl_click_in_rect(dl_k1-kr, row1_cy-kr, kr*2, kr*2) ? (slider1=4; slider_automate(slider1););
  loop_length_seconds = slider1;
  strcpy(#lbl, "LOOP");
  draw_label_at(dl_k1, row1_cy - kr - 14);
  sprintf(#val, "%.1f s", slider1);
  draw_value_at(dl_k1, row1_cy + kr + 4);
);

// FEEDBACK
ui_push_rect(dl_k2-kr, row1_cy-kr, kr*2, kr*2);
  slider2 = control_dial(slider2, 0, 1, 0);
  slider_automate(slider2);
ui_pop();
dbl_click_in_rect(dl_k2-kr, row1_cy-kr, kr*2, kr*2) ? (slider2=0.8; slider_automate(slider2););
feedback = slider2;
strcpy(#lbl, "FEEDBACK");
draw_label_at(dl_k2, row1_cy - kr - 14);
sprintf(#val, "%.2f", slider2);
draw_value_at(dl_k2, row1_cy + kr + 4);

// DAMPING
ui_push_rect(dl_k3-kr, row1_cy-kr, kr*2, kr*2);
  slider4 = control_dial(slider4, 0, 1, 0);
  slider_automate(slider4);
ui_pop();
dbl_click_in_rect(dl_k3-kr, row1_cy-kr, kr*2, kr*2) ? (slider4=0; slider_automate(slider4););
damping = slider4;
cutoff_freq = 20000 - damping * 19000;
damping_coeff = exp(-2 * $pi * cutoff_freq / srate);
damping_coeff_inv = 1 - damping_coeff;
strcpy(#lbl, "DAMPING");
draw_label_at(dl_k3, row1_cy - kr - 14);
sprintf(#val, "%.2f", slider4);
draw_value_at(dl_k3, row1_cy + kr + 4);

// ============================================================
// ROW 1B — TEMPO SYNC (purple/violet)
// ============================================================
draw_section_box(sync_x, row1_y, sync_w, row1_h, 0.12, 0.62, 0.88, "TEMPO SYNC");

// Label above widget
gfx_r=0.71; gfx_g=0.71; gfx_b=0.75; gfx_a=1;
gfx_setfont(1, "Arial", 10);
gfx_measurestr("DELAY SYNC", lw, lh);
gfx_x = sync_ctr_x - lw/2; gfx_y = sync_lbl_y;
gfx_drawstr("DELAY SYNC");

// Selector box
slider8 ? (gfx_r=0.16; gfx_g=0.16; gfx_b=0.18;)
        : (gfx_r=0.12; gfx_g=0.12; gfx_b=0.13;);
gfx_a=1;
gfx_rect(sync_box_x, sync_box_y, sync_box_w, sync_box_h);
gfx_r=0.28; gfx_g=0.28; gfx_b=0.32; gfx_a=1;
gfx_rect(sync_box_x,            sync_box_y,            sync_box_w, 1);
gfx_rect(sync_box_x,            sync_box_y+sync_box_h, sync_box_w, 1);
gfx_rect(sync_box_x,            sync_box_y,            1, sync_box_h);
gfx_rect(sync_box_x+sync_box_w, sync_box_y,            1, sync_box_h+1);

// Up/down arrows
slider8 ? (
  ui_push_rect(sync_box_x, sync_box_y, sync_box_w, arrow_h);
    ui_click() ? (slider9 = min(6, slider9+1); slider_automate(slider9); time_division = slider9;);
  ui_pop();
  ui_push_rect(sync_box_x, sync_box_y+sync_box_h-arrow_h, sync_box_w, arrow_h);
    ui_click() ? (slider9 = max(0, slider9-1); slider_automate(slider9); time_division = slider9;);
  ui_pop();
  gfx_r=0.55; gfx_g=0.55; gfx_b=0.58;
) : (
  gfx_r=0.30; gfx_g=0.30; gfx_b=0.32;
);
gfx_a=1;
gfx_triangle(sync_box_x+sync_box_w/2,   sync_box_y+3,
             sync_box_x+sync_box_w/2-6, sync_box_y+9,
             sync_box_x+sync_box_w/2+6, sync_box_y+9);
gfx_triangle(sync_box_x+sync_box_w/2,   sync_box_y+sync_box_h-3,
             sync_box_x+sync_box_w/2-6, sync_box_y+sync_box_h-9,
             sync_box_x+sync_box_w/2+6, sync_box_y+sync_box_h-9);

// Division value
slider8 ? (gfx_r=0.72; gfx_g=0.30; gfx_b=1.0;) : (gfx_r=0.35; gfx_g=0.35; gfx_b=0.37;);
gfx_a=1; gfx_setfont(1, "Arial", 11, 'b');
time_division == 0 ? strcpy(#sync_val, "1/4")  :
time_division == 1 ? strcpy(#sync_val, "1/2")  :
time_division == 2 ? strcpy(#sync_val, "1")    :
time_division == 3 ? strcpy(#sync_val, "2")    :
time_division == 4 ? strcpy(#sync_val, "4")    :
time_division == 5 ? strcpy(#sync_val, "8")    :
                     strcpy(#sync_val, "16");
gfx_measurestr(#sync_val, sw, sh);
gfx_x = sync_box_x + (sync_box_w - sw)/2;
gfx_y = sync_box_y + (sync_box_h - sh)/2;
gfx_drawstr(#sync_val);

// SYNC button
ui_push_rect(sync_btn_x, sync_box_y, sync_btn_w, sync_box_h);
  slider8 ? control_background_inset() : control_background_enabled("none");
  ui_color(255, 255, 255);
  ui_align(0.5, 0.5);
  ui_fontsize(7);
  ui_text("SYNC");
  slider8 ? control_finish_inset() : control_finish_enabled("none");
  ui_click() ? (
    slider8 = 1 - slider8;
    slider_automate(slider8);
    tempo_sync = slider8;
    slider8 ? (
      current_tempo = tempo;
      current_tempo <= 0 ? current_tempo = 120;
      beat_length = 60 / current_tempo;
      time_division == 0 ? loop_length_seconds = beat_length :
      time_division == 1 ? loop_length_seconds = beat_length * 2 :
      time_division == 2 ? loop_length_seconds = beat_length * 4 :
      time_division == 3 ? loop_length_seconds = beat_length * 8 :
      time_division == 4 ? loop_length_seconds = beat_length * 16 :
      time_division == 5 ? loop_length_seconds = beat_length * 32 :
                           loop_length_seconds = beat_length * 64;
    ) : (
      loop_length_seconds = slider1;
    );
    loop_size = max(1, min(max_buffer_size - 1, srate * loop_length_seconds));
  );
ui_pop();

// ============================================================
// ROW 2A — TAPE EFFECTS (amber)
// ============================================================
draw_section_box(tape_x, row2_y, tape_w, row2_h, 0.80, 0.58, 0.08, "TAPE EFFECTS");

// SAT MODE switch at knob height
sw_h = 20;
draw_switch_label(tape_sw, row2_cy - kr - 14, "SAT MODE");
ui_push_rect(tape_sw - 28, row2_cy - sw_h/2, 56, sw_h);
  slider6 = control_switch(slider6);
  slider_automate(slider6);
ui_pop();
saturation_mode = slider6;
sw_lbl = slider6 ? "TAPE" : "SOFT";
slider6 ? (gfx_r=0.80; gfx_g=0.58; gfx_b=0.08;) : (gfx_r=0.60; gfx_g=0.60; gfx_b=0.60;);
gfx_a=1; gfx_setfont(1, "Arial", 10);
gfx_measurestr(sw_lbl, lw, lh);
gfx_x = tape_sw - lw/2; gfx_y = row2_cy + sw_h/2 + 4;
gfx_drawstr(sw_lbl);

// SATURATION
ui_push_rect(tape_k1-kr, row2_cy-kr, kr*2, kr*2);
  slider5 = control_dial(slider5, 0, 1, 0);
  slider_automate(slider5);
ui_pop();
dbl_click_in_rect(tape_k1-kr, row2_cy-kr, kr*2, kr*2) ? (slider5=0; slider_automate(slider5););
saturation = slider5;
saturation > 0 ? (
  slider6 ? (saturation_drive = 1+saturation*10; saturation_scale = 1/(saturation_drive*0.5);)
          : (saturation_drive = 1+saturation*5;  saturation_scale = 1/(saturation_drive*0.7););
);
strcpy(#lbl, "SATURATION");
draw_label_at(tape_k1, row2_cy - kr - 14);
sprintf(#val, "%.2f", slider5);
draw_value_at(tape_k1, row2_cy + kr + 4);

// W&F
ui_push_rect(tape_k2-kr, row2_cy-kr, kr*2, kr*2);
  slider7 = control_dial(slider7, 0, 1, 0);
  slider_automate(slider7);
ui_pop();
dbl_click_in_rect(tape_k2-kr, row2_cy-kr, kr*2, kr*2) ? (slider7=0; slider_automate(slider7););
wow_flutter = slider7;
strcpy(#lbl, "W&F");
draw_label_at(tape_k2, row2_cy - kr - 14);
sprintf(#val, "%.2f", slider7);
draw_value_at(tape_k2, row2_cy + kr + 4);

// ============================================================
// ROW 2B — OUTPUT (cyan)
// ============================================================
draw_section_box(out_x, row2_y, out_w, row2_h, 0.22, 0.72, 0.32, "OUTPUT");

// MIX
ui_push_rect(out_k1-kr, row2_cy-kr, kr*2, kr*2);
  slider3 = control_dial(slider3, 0, 1, 0);
  slider_automate(slider3);
ui_pop();
dbl_click_in_rect(out_k1-kr, row2_cy-kr, kr*2, kr*2) ? (slider3=0.5; slider_automate(slider3););
mix = slider3;
mix_inv = 1 - mix;
strcpy(#lbl, "MIX");
draw_label_at(out_k1, row2_cy - kr - 14);
sprintf(#val, "%.0f%%", slider3*100);
draw_value_at(out_k1, row2_cy + kr + 4);

// LF MONO
ui_push_rect(out_k2-kr, row2_cy-kr, kr*2, kr*2);
  slider10 = control_dial(slider10, 0, 300, 0);
  slider_automate(slider10);
ui_pop();
dbl_click_in_rect(out_k2-kr, row2_cy-kr, kr*2, kr*2) ? (slider10=0; slider_automate(slider10););
mono_bass_freq = slider10;
mono_bass_freq > 0 ? (
  mb_coeff = exp(-2 * $pi * mono_bass_freq / srate);
  mb_coeff_inv = 1 - mb_coeff;
);
strcpy(#lbl, "LF MONO");
draw_label_at(out_k2, row2_cy - kr - 14);
slider10 == 0 ? strcpy(#val, "OFF") : sprintf(#val, "%.0f Hz", slider10);
draw_value_at(out_k2, row2_cy + kr + 4);

mouse_cap_last = mouse_cap;
