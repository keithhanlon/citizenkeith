desc: Garden Hose Delay
version: 2.0
author: citizenkeith and Claude AI
about:
  # Garden Hose Delay - Time Cube Emulator
  An emulation of the Cooper Time Cube, a classic electromechanical delay unit
  that created its characteristic doubling effect by sending audio through a
  coiled garden hose as a transmission line.

// @changelog
//   2.0 - STEREO and OUTPUT sections swapped in bottom row.
//         Default REAPER GUI hidden (options: no_meter).
//         Added full ReaPack metadata (provides, screenshot, links).
//   1.4 - OUTPUT section (green) for Wet Mix. STEREO header blue.
//         Row heights increased for bottom breathing room.
//   1.3 - GUI: ECHOES/EQ/STEREO sections. ui_setup/freemem fix.
//   1.2 - Stereo Width as continuous 0-2ms R channel delay offset.
//   1.1 - Fixed buffer size, drift_slew, Character slider range.


@reapack
provides:
  citizenkeith-ui-lib.jsfx-inc
screenshot: https://citizenkeith.com/plugins/garden-hose-delay/screenshot.png
link: Home Page https://citizenkeith.com
link: ReaPack Repository https://citizenkeith.com/reapack/index.xml

import citizenkeith-ui-lib.jsfx-inc

slider1:14<7,28,0.1>-Echo A Delay (ms)
slider2:0.75<0,1,0.01>-Echo A Level
slider3:28<14,56,0.1>-Echo B Delay (ms)
slider4:0.75<0,1,0.01>-Echo B Level
slider5:0.20<0,1,0.01>-Wet Mix
slider6:0<0,1,1{Normal,Inverted}>-Polarity
slider7:100<80,120,1>-High Pass Freq (Hz)
slider8:10000<8000,12000,100>-Low Pass Freq (Hz)
slider9:0.5<0,1,0.01>-Character
slider10:0<0,2,0.01>-Stereo Width (ms)

@init

buf_size = ceil(0.063 * srate);
freemem = 0;
buf_L = freemem; freemem += buf_size;
buf_R = freemem; freemem += buf_size;
buf_pos = 0;

hp_x1_L = hp_x2_L = hp_y1_L = hp_y2_L = 0;
lp_x1_L = lp_x2_L = lp_y1_L = lp_y2_L = 0;
pk_x1_L = pk_x2_L = pk_y1_L = pk_y2_L = 0;
hp_x1_R = hp_x2_R = hp_y1_R = hp_y2_R = 0;
lp_x1_R = lp_x2_R = lp_y1_R = lp_y2_R = 0;
pk_x1_R = pk_x2_R = pk_y1_R = pk_y2_R = 0;

lfo_phase_L = 0; lfo_phase_R = 0.25;
drift_L = 0; drift_R = 0;
drift_target_L = 0; drift_target_R = 0;
drift_counter = 0; drift_slew = 0.0001;

dbl_click_time = 0;
dbl_click_x = dbl_click_y = 0;
dbl_click_fired = 0;
dbl_click_cx = dbl_click_cy = 0;
mouse_cap_last = 0;

ui_setup(freemem);

function soft_saturate(x, drive, asym) (
  x *= (1 + drive * 4);
  x += x * x * asym * 0.1;
  sat = x / sqrt(1 + x * x);
  sat / (1 + drive * 0.5);
);

function check_dbl_click() local(mx, my, now, dt) (
  mx = mouse_x; my = mouse_y; now = time_precise();
  (mouse_cap & 1) && !(mouse_cap_last & 1) ? (
    dt = now - dbl_click_time;
    (dt < 0.4) && (dt > 0.05) && (abs(mx - dbl_click_x) < 8) && (abs(my - dbl_click_y) < 8) ? (
      dbl_click_fired = 1; dbl_click_cx = mx; dbl_click_cy = my;
    ) : (
      dbl_click_fired = 0;
    );
    dbl_click_time = now; dbl_click_x = mx; dbl_click_y = my;
  ) : (
    dbl_click_fired = 0;
  );
);

function dbl_click_in_rect(rx, ry, rw, rh) (
  dbl_click_fired &&
  (dbl_click_cx >= rx) && (dbl_click_cx < rx + rw) &&
  (dbl_click_cy >= ry) && (dbl_click_cy < ry + rh);
);

function draw_label_at(lx, ly) local(lw, lh) (
  gfx_r = 0.68; gfx_g = 0.68; gfx_b = 0.72; gfx_a = 1;
  gfx_setfont(1, "Arial", 10);
  gfx_measurestr(#lbl, lw, lh);
  gfx_x = lx - lw/2; gfx_y = ly;
  gfx_drawstr(#lbl);
);

function draw_value_at(vx, vy) local(vw, vh) (
  gfx_r = 1.0; gfx_g = 0.82; gfx_b = 0.44; gfx_a = 1;
  gfx_setfont(1, "Arial", 10);
  gfx_measurestr(#val, vw, vh);
  gfx_x = vx - vw/2; gfx_y = vy;
  gfx_drawstr(#val);
);

function draw_section_box(bx, by, bw, bh, hr, hg, hb, hdr) local(tw, th) (
  gfx_r=0.11; gfx_g=0.11; gfx_b=0.13; gfx_a=1; gfx_rect(bx,by,bw,bh);
  gfx_r=hr; gfx_g=hg; gfx_b=hb; gfx_a=1; gfx_rect(bx,by,bw,22);
  gfx_r=0.08; gfx_g=0.08; gfx_b=0.08; gfx_a=1;
  gfx_setfont(1,"Arial",10,'b'); gfx_measurestr(hdr,tw,th);
  gfx_x=bx+bw/2-tw/2; gfx_y=by+11-th/2; gfx_drawstr(hdr);
  gfx_r=0.28; gfx_g=0.28; gfx_b=0.32; gfx_a=1;
  gfx_rect(bx,by,bw,1); gfx_rect(bx,by+bh,bw,1);
  gfx_rect(bx,by,1,bh); gfx_rect(bx+bw,by,1,bh+1);
);

@slider

echoA_samples = (slider1 / 1000) * srate;
echoB_samples = (slider3 / 1000) * srate;
echoA_level = slider2; echoB_level = slider4;
wet = slider5; dry = 1.0 - wet;
polarity = slider6 == 1 ? -1 : 1;
stereo_offset_samples = (slider10 / 1000) * srate;
mod_depth_samples = (0.15 / 1000) * srate;
lfo_inc = 0.2 / srate;
drive_amount = 0.2; asymmetry = 0.3;

hp_freq = slider7;
hp_w0 = 2 * $pi * hp_freq / srate;
hp_alpha = sin(hp_w0) / (2 * 0.7071);
hp_b0 = (1 + cos(hp_w0)) / 2; hp_b1 = -(1 + cos(hp_w0)); hp_b2 = (1 + cos(hp_w0)) / 2;
hp_a0 = 1 + hp_alpha; hp_a1 = -2 * cos(hp_w0); hp_a2 = 1 - hp_alpha;
hp_b0 /= hp_a0; hp_b1 /= hp_a0; hp_b2 /= hp_a0; hp_a1 /= hp_a0; hp_a2 /= hp_a0;

lp_freq = slider8;
lp_w0 = 2 * $pi * lp_freq / srate;
lp_alpha = sin(lp_w0) / (2 * 0.7071);
lp_b0 = (1 - cos(lp_w0)) / 2; lp_b1 = 1 - cos(lp_w0); lp_b2 = (1 - cos(lp_w0)) / 2;
lp_a0 = 1 + lp_alpha; lp_a1 = -2 * cos(lp_w0); lp_a2 = 1 - lp_alpha;
lp_b0 /= lp_a0; lp_b1 /= lp_a0; lp_b2 /= lp_a0; lp_a1 /= lp_a0; lp_a2 /= lp_a0;

pk_gain_db = (slider9 - 0.5) * 12;
pk_A = 10^(pk_gain_db / 40);
pk_w0 = 2 * $pi * 2000 / srate;
pk_alpha = sin(pk_w0) / (2 * 1.5);
pk_b0 = 1 + pk_alpha * pk_A; pk_b1 = -2 * cos(pk_w0); pk_b2 = 1 - pk_alpha * pk_A;
pk_a0 = 1 + pk_alpha / pk_A; pk_a1 = -2 * cos(pk_w0); pk_a2 = 1 - pk_alpha / pk_A;
pk_b0 /= pk_a0; pk_b1 /= pk_a0; pk_b2 /= pk_a0; pk_a1 /= pk_a0; pk_a2 /= pk_a0;

@sample

buf_L[buf_pos] = spl0; buf_R[buf_pos] = spl1;

lfo_phase_L += lfo_inc; lfo_phase_L >= 1 ? lfo_phase_L -= 1;
lfo_phase_R += lfo_inc; lfo_phase_R >= 1 ? lfo_phase_R -= 1;
lfo_L = sin(lfo_phase_L * 2 * $pi);
lfo_R = sin(lfo_phase_R * 2 * $pi);

drift_counter += 1;
drift_counter >= srate * 0.5 ? (
  drift_counter = 0;
  drift_target_L = (rand() * 2 - 1);
  drift_target_R = (rand() * 2 - 1);
);
drift_L += (drift_target_L - drift_L) * drift_slew;
drift_R += (drift_target_R - drift_R) * drift_slew;

mod_L = (lfo_L * 0.4 + drift_L * 0.6) * mod_depth_samples;
mod_R = (lfo_R * 0.4 + drift_R * 0.6) * mod_depth_samples;

readA_L = buf_pos - echoA_samples - mod_L;
readA_L < 0 ? readA_L += buf_size; readA_L >= buf_size ? readA_L -= buf_size;
readA_R = buf_pos - echoA_samples - stereo_offset_samples - mod_R;
readA_R < 0 ? readA_R += buf_size; readA_R >= buf_size ? readA_R -= buf_size;

readB_L = buf_pos - echoB_samples - mod_L;
readB_L < 0 ? readB_L += buf_size; readB_L >= buf_size ? readB_L -= buf_size;
readB_R = buf_pos - echoB_samples - stereo_offset_samples - mod_R;
readB_R < 0 ? readB_R += buf_size; readB_R >= buf_size ? readB_R -= buf_size;

fracA_L = readA_L - floor(readA_L);
idxAa_L = floor(readA_L); idxAb_L = idxAa_L + 1; idxAb_L >= buf_size ? idxAb_L -= buf_size;
delayedA_L = buf_L[idxAa_L] * (1 - fracA_L) + buf_L[idxAb_L] * fracA_L;

fracA_R = readA_R - floor(readA_R);
idxAa_R = floor(readA_R); idxAb_R = idxAa_R + 1; idxAb_R >= buf_size ? idxAb_R -= buf_size;
delayedA_R = buf_R[idxAa_R] * (1 - fracA_R) + buf_R[idxAb_R] * fracA_R;

fracB_L = readB_L - floor(readB_L);
idxBa_L = floor(readB_L); idxBb_L = idxBa_L + 1; idxBb_L >= buf_size ? idxBb_L -= buf_size;
delayedB_L = buf_L[idxBa_L] * (1 - fracB_L) + buf_L[idxBb_L] * fracB_L;

fracB_R = readB_R - floor(readB_R);
idxBa_R = floor(readB_R); idxBb_R = idxBa_R + 1; idxBb_R >= buf_size ? idxBb_R -= buf_size;
delayedB_R = buf_R[idxBa_R] * (1 - fracB_R) + buf_R[idxBb_R] * fracB_R;

wet_L = delayedA_L * echoA_level + delayedB_L * echoB_level;
wet_R = delayedA_R * echoA_level + delayedB_R * echoB_level;

hp_out_L = hp_b0*wet_L + hp_b1*hp_x1_L + hp_b2*hp_x2_L - hp_a1*hp_y1_L - hp_a2*hp_y2_L;
hp_x2_L=hp_x1_L; hp_x1_L=wet_L; hp_y2_L=hp_y1_L; hp_y1_L=hp_out_L;
lp_out_L = lp_b0*hp_out_L + lp_b1*lp_x1_L + lp_b2*lp_x2_L - lp_a1*lp_y1_L - lp_a2*lp_y2_L;
lp_x2_L=lp_x1_L; lp_x1_L=hp_out_L; lp_y2_L=lp_y1_L; lp_y1_L=lp_out_L;
pk_out_L = pk_b0*lp_out_L + pk_b1*pk_x1_L + pk_b2*pk_x2_L - pk_a1*pk_y1_L - pk_a2*pk_y2_L;
pk_x2_L=pk_x1_L; pk_x1_L=lp_out_L; pk_y2_L=pk_y1_L; pk_y1_L=pk_out_L;

hp_out_R = hp_b0*wet_R + hp_b1*hp_x1_R + hp_b2*hp_x2_R - hp_a1*hp_y1_R - hp_a2*hp_y2_R;
hp_x2_R=hp_x1_R; hp_x1_R=wet_R; hp_y2_R=hp_y1_R; hp_y1_R=hp_out_R;
lp_out_R = lp_b0*hp_out_R + lp_b1*lp_x1_R + lp_b2*lp_x2_R - lp_a1*lp_y1_R - lp_a2*lp_y2_R;
lp_x2_R=lp_x1_R; lp_x1_R=hp_out_R; lp_y2_R=lp_y1_R; lp_y1_R=lp_out_R;
pk_out_R = pk_b0*lp_out_R + pk_b1*pk_x1_R + pk_b2*pk_x2_R - pk_a1*pk_y1_R - pk_a2*pk_y2_R;
pk_x2_R=pk_x1_R; pk_x1_R=lp_out_R; pk_y2_R=pk_y1_R; pk_y1_R=pk_out_R;

sat_L = soft_saturate(pk_out_L, drive_amount, asymmetry);
sat_R = soft_saturate(pk_out_R, drive_amount, asymmetry);

spl0 = spl0 * dry + sat_L * polarity * wet;
spl1 = spl1 * dry + sat_R * polarity * wet;

buf_pos += 1; buf_pos >= buf_size ? buf_pos = 0;


@gfx 560 386

control_start("main", "tron");

ui_screen() == "main" ? (

gfx_r = 0.14; gfx_g = 0.14; gfx_b = 0.16; gfx_a = 1;
gfx_rect(0, 0, gfx_w, gfx_h);

check_dbl_click();

gfx_r = 0.78; gfx_g = 0.78; gfx_b = 0.82; gfx_a = 1;
gfx_setfont(1, "Trebuchet MS", 14, 'b');
gfx_x = 12; gfx_y = 8;
gfx_drawstr("GARDEN HOSE DELAY");

pad    = 8;
row1_y = 36;  row1_h = 165;  row1_cy = row1_y + 60;
row2_y = row1_y + row1_h + pad;
row2_h = 165;  row2_cy = row2_y + 60;

total_w  = gfx_w - pad * 2;
echo_x = pad; echo_w = total_w;
eq_w     = floor(total_w * 0.45);
stereo_w = floor(total_w * 0.27);
out_w    = total_w - eq_w - stereo_w - pad * 2;
eq_x     = pad;
stereo_x = eq_x + eq_w + pad;
out_x    = stereo_x + stereo_w + pad;
kr = 22;

// ECHOES (red)
draw_section_box(echo_x, row1_y, echo_w, row1_h, 0.82, 0.18, 0.14, "ECHOES");
cw = echo_w / 4;
cx1 = echo_x + cw*0.5;  cx2 = echo_x + cw*1.5;
cx3 = echo_x + cw*2.5;  cx4 = echo_x + cw*3.5;

ui_push_rect(cx1-kr, row1_cy-kr, kr*2, kr*2);
  ui_automate(slider1, control_dial(slider1, 7, 28, 0, 14));
ui_pop();
dbl_click_in_rect(cx1-kr,row1_cy-kr,kr*2,kr*2) ? (slider1=14; ui_automate(slider1,slider1););
strcpy(#lbl,"ECHO A"); draw_label_at(cx1, row1_cy-kr-14);
sprintf(#val,"%.1f ms",slider1); draw_value_at(cx1, row1_cy+kr+4);

ui_push_rect(cx2-kr, row1_cy-kr, kr*2, kr*2);
  ui_automate(slider2, control_dial(slider2, 0, 1, 0, 0.75));
ui_pop();
dbl_click_in_rect(cx2-kr,row1_cy-kr,kr*2,kr*2) ? (slider2=0.75; ui_automate(slider2,slider2););
strcpy(#lbl,"LEVEL A"); draw_label_at(cx2, row1_cy-kr-14);
sprintf(#val,"%.2f",slider2); draw_value_at(cx2, row1_cy+kr+4);

ui_push_rect(cx3-kr, row1_cy-kr, kr*2, kr*2);
  ui_automate(slider3, control_dial(slider3, 14, 56, 0, 28));
ui_pop();
dbl_click_in_rect(cx3-kr,row1_cy-kr,kr*2,kr*2) ? (slider3=28; ui_automate(slider3,slider3););
strcpy(#lbl,"ECHO B"); draw_label_at(cx3, row1_cy-kr-14);
sprintf(#val,"%.1f ms",slider3); draw_value_at(cx3, row1_cy+kr+4);

ui_push_rect(cx4-kr, row1_cy-kr, kr*2, kr*2);
  ui_automate(slider4, control_dial(slider4, 0, 1, 0, 0.75));
ui_pop();
dbl_click_in_rect(cx4-kr,row1_cy-kr,kr*2,kr*2) ? (slider4=0.75; ui_automate(slider4,slider4););
strcpy(#lbl,"LEVEL B"); draw_label_at(cx4, row1_cy-kr-14);
sprintf(#val,"%.2f",slider4); draw_value_at(cx4, row1_cy+kr+4);

// EQ (amber)
draw_section_box(eq_x, row2_y, eq_w, row2_h, 0.80, 0.55, 0.08, "EQ");
eq_cw=eq_w/3; eq_cx1=eq_x+eq_cw*0.5; eq_cx2=eq_x+eq_cw*1.5; eq_cx3=eq_x+eq_cw*2.5;

ui_push_rect(eq_cx1-kr, row2_cy-kr, kr*2, kr*2);
  ui_automate(slider7, control_dial(slider7, 80, 120, 0, 100));
ui_pop();
dbl_click_in_rect(eq_cx1-kr,row2_cy-kr,kr*2,kr*2) ? (slider7=100; ui_automate(slider7,slider7););
strcpy(#lbl,"HIGH PASS"); draw_label_at(eq_cx1, row2_cy-kr-14);
sprintf(#val,"%d Hz",floor(slider7)); draw_value_at(eq_cx1, row2_cy+kr+4);

ui_push_rect(eq_cx2-kr, row2_cy-kr, kr*2, kr*2);
  ui_automate(slider8, control_dial(slider8, 8000, 12000, 0, 10000));
ui_pop();
dbl_click_in_rect(eq_cx2-kr,row2_cy-kr,kr*2,kr*2) ? (slider8=10000; ui_automate(slider8,slider8););
strcpy(#lbl,"LOW PASS"); draw_label_at(eq_cx2, row2_cy-kr-14);
sprintf(#val,"%d Hz",floor(slider8)); draw_value_at(eq_cx2, row2_cy+kr+4);

ui_push_rect(eq_cx3-kr, row2_cy-kr, kr*2, kr*2);
  ui_automate(slider9, control_dial(slider9, 0, 1, 0, 0.5));
ui_pop();
dbl_click_in_rect(eq_cx3-kr,row2_cy-kr,kr*2,kr*2) ? (slider9=0.5; ui_automate(slider9,slider9););
strcpy(#lbl,"CHARACTER"); draw_label_at(eq_cx3, row2_cy-kr-14);
pk_disp = (slider9 - 0.5) * 12;
pk_disp >= 0 ? sprintf(#val,"+%.1f dB",pk_disp) : sprintf(#val,"%.1f dB",pk_disp);
draw_value_at(eq_cx3, row2_cy+kr+4);

// STEREO (blue)
draw_section_box(stereo_x, row2_y, stereo_w, row2_h, 0.18, 0.45, 0.82, "STEREO");
st_cw=stereo_w/2; st_cx1=stereo_x+st_cw*0.5; st_cx2=stereo_x+st_cw*1.5;

sw_h = 22;
ui_push_rect(st_cx1-26, row2_cy-sw_h/2, 52, sw_h);
  ui_automate(slider6, control_switch(slider6));
ui_pop();
strcpy(#lbl,"POLARITY"); draw_label_at(st_cx1, row2_cy-sw_h/2-14);
slider6 == 1 ? (
  gfx_r=1.0; gfx_g=0.40; gfx_b=0.20; sw_str="INVERT";
) : (
  gfx_r=0.68; gfx_g=0.68; gfx_b=0.72; sw_str="NORMAL";
);
gfx_a=1; gfx_setfont(1,"Arial",10);
gfx_measurestr(sw_str, sw_lw, sw_lh);
gfx_x=st_cx1-sw_lw/2; gfx_y=row2_cy+sw_h/2+4;
gfx_drawstr(sw_str);

ui_push_rect(st_cx2-kr, row2_cy-kr, kr*2, kr*2);
  ui_automate(slider10, control_dial(slider10, 0, 2, 0, 0));
ui_pop();
dbl_click_in_rect(st_cx2-kr,row2_cy-kr,kr*2,kr*2) ? (slider10=0; ui_automate(slider10,slider10););
strcpy(#lbl,"WIDTH"); draw_label_at(st_cx2, row2_cy-kr-14);
sprintf(#val,"%.2f ms",slider10); draw_value_at(st_cx2, row2_cy+kr+4);

// OUTPUT (green)
draw_section_box(out_x, row2_y, out_w, row2_h, 0.16, 0.68, 0.28, "OUTPUT");
out_cx = out_x + out_w / 2;

ui_push_rect(out_cx-kr, row2_cy-kr, kr*2, kr*2);
  ui_automate(slider5, control_dial(slider5, 0, 1, 0, 0.20));
ui_pop();
dbl_click_in_rect(out_cx-kr,row2_cy-kr,kr*2,kr*2) ? (slider5=0.20; ui_automate(slider5,slider5););
strcpy(#lbl,"WET MIX"); draw_label_at(out_cx, row2_cy-kr-14);
sprintf(#val,"%.0f%%",slider5*100); draw_value_at(out_cx, row2_cy+kr+4);

mouse_cap_last = mouse_cap;

) : ui_system();
