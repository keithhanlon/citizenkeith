desc:Probabilistic MIDI Note Generator
version: 2.0
author: citizenkeith and Claude AI
about: Generative MIDI pattern generator with scale-aware probabilistic note selection
// @version 2.0
// @author citizenkeith
// @license GPL v3
// @depends ../citizenkeith-ui-lib/citizenkeith-ui-lib.jsfx
// @about
//   Generative MIDI pattern generator. Outputs note-on/off events based on
//   probabilistic pattern generation across 12 scales. Supports project tempo
//   sync or internal BPM. Fully MIDI-spec compliant note-off messages.
// @changelog
//   v2.0
//     Slider labels changed to white for readability
//   v1.1
//     Fixed pattern regeneration firing every block at step 0 (now uses flag)
//     Fixed step_length not updating when project tempo changes
//     Fixed note-off velocity (now sends 0, per MIDI spec)
//     Restored free-running current_time (runs without transport)
//     Fixed note duration default (now fraction of step, not raw samples)
//     Added note_count overflow recovery
//     Optimized note-off removal: swap-with-last instead of array shift
//     Added custom GUI: horizontal sliders, color-coded section headers

options: no_meter gfx_idle

in_pin:none
out_pin:none

slider1:60<0,127,1>-Root Note (MIDI, C4=60)
slider2:0<0,11,1{Major,Natural Minor,Harmonic Minor,Melodic Minor,Dorian,Phrygian,Lydian,Mixolydian,Locrian,Pentatonic Major,Pentatonic Minor,Blues}>-Scale Type
slider3:50<0,100,1>-Pattern Repeat Probability (%)
slider4:70<0,100,1>-Note Trigger Probability (%)
slider5:64<1,127,1>-Base Velocity
slider6:30<0,100,1>-Velocity Randomness (%)
slider7:75<10,100,1>-Note Duration (% of step)
slider8:20<0,100,1>-Duration Randomness (%)
slider9:4<1,16,1>-Steps per Beat
slider10:2<1,8,1>-Pattern Length (beats)
slider11:2<1,4,1>-Octave Range
slider12:1<0,1,1{Internal Tempo,Sync to Project}>-Tempo Sync
slider13:120<40,300,1>-Internal Tempo (BPM)

@init

rand(1);

scale_major      =  0;  scale_major[0]=0;  scale_major[1]=2;  scale_major[2]=4;  scale_major[3]=5;  scale_major[4]=7;  scale_major[5]=9;  scale_major[6]=11; scale_major[7]=7;
scale_minor      =  8;  scale_minor[0]=0;  scale_minor[1]=2;  scale_minor[2]=3;  scale_minor[3]=5;  scale_minor[4]=7;  scale_minor[5]=8;  scale_minor[6]=10; scale_minor[7]=7;
scale_harm_minor = 16;  scale_harm_minor[0]=0; scale_harm_minor[1]=2; scale_harm_minor[2]=3; scale_harm_minor[3]=5; scale_harm_minor[4]=7; scale_harm_minor[5]=8; scale_harm_minor[6]=11; scale_harm_minor[7]=7;
scale_mel_minor  = 24;  scale_mel_minor[0]=0;  scale_mel_minor[1]=2;  scale_mel_minor[2]=3;  scale_mel_minor[3]=5;  scale_mel_minor[4]=7;  scale_mel_minor[5]=9;  scale_mel_minor[6]=11; scale_mel_minor[7]=7;
scale_dorian     = 32;  scale_dorian[0]=0;    scale_dorian[1]=2;    scale_dorian[2]=3;    scale_dorian[3]=5;    scale_dorian[4]=7;    scale_dorian[5]=9;    scale_dorian[6]=10;   scale_dorian[7]=7;
scale_phrygian   = 40;  scale_phrygian[0]=0;  scale_phrygian[1]=1;  scale_phrygian[2]=3;  scale_phrygian[3]=5;  scale_phrygian[4]=7;  scale_phrygian[5]=8;  scale_phrygian[6]=10; scale_phrygian[7]=7;
scale_lydian     = 48;  scale_lydian[0]=0;    scale_lydian[1]=2;    scale_lydian[2]=4;    scale_lydian[3]=6;    scale_lydian[4]=7;    scale_lydian[5]=9;    scale_lydian[6]=11;   scale_lydian[7]=7;
scale_mixolydian = 56;  scale_mixolydian[0]=0; scale_mixolydian[1]=2; scale_mixolydian[2]=4; scale_mixolydian[3]=5; scale_mixolydian[4]=7; scale_mixolydian[5]=9; scale_mixolydian[6]=10; scale_mixolydian[7]=7;
scale_locrian    = 64;  scale_locrian[0]=0;   scale_locrian[1]=1;   scale_locrian[2]=3;   scale_locrian[3]=5;   scale_locrian[4]=6;   scale_locrian[5]=8;   scale_locrian[6]=10;  scale_locrian[7]=7;
scale_pent_maj   = 72;  scale_pent_maj[0]=0;  scale_pent_maj[1]=2;  scale_pent_maj[2]=4;  scale_pent_maj[3]=7;  scale_pent_maj[4]=9;  scale_pent_maj[5]=5;
scale_pent_min   = 78;  scale_pent_min[0]=0;  scale_pent_min[1]=3;  scale_pent_min[2]=5;  scale_pent_min[3]=7;  scale_pent_min[4]=10; scale_pent_min[5]=5;
scale_blues      = 84;  scale_blues[0]=0;     scale_blues[1]=3;     scale_blues[2]=5;     scale_blues[3]=6;     scale_blues[4]=7;     scale_blues[5]=10;    scale_blues[6]=6;

pattern_buffer = 1000;
active_notes   = 2000;

pattern_step       = 0;
pattern_just_reset = 0;
note_count         = 0;
next_step_time     = 0;
current_time       = 0;

drag_slider      = -1;
last_mouse_btn   = 0;
row_idx          = 0;
last_click_time  = 0;
last_click_row   = -1;
dbl_click_thresh = srate * 0.35;  // 350ms window

// Default values indexed by row_idx order (0-based, matches slider draw order)
// Order: root, scale, octave, repeat%, trigger%, steps, length, base_vel, vel_rand, duration, dur_rand, sync, bpm
defaults = 500;
defaults[0]  = 60;   // Root Note
defaults[1]  = 0;    // Scale Type
defaults[2]  = 2;    // Octave Range
defaults[3]  = 50;   // Repeat Probability
defaults[4]  = 70;   // Trigger Probability
defaults[5]  = 4;    // Steps per Beat
defaults[6]  = 2;    // Pattern Length
defaults[7]  = 64;   // Base Velocity
defaults[8]  = 30;   // Velocity Randomness
defaults[9]  = 75;   // Note Duration
defaults[10] = 20;   // Duration Randomness
defaults[11] = 1;    // Tempo Sync
defaults[12] = 120;  // Internal BPM

function get_scale(scale_type) (
  scale_type == 0  ? scale_major      :
  scale_type == 1  ? scale_minor      :
  scale_type == 2  ? scale_harm_minor :
  scale_type == 3  ? scale_mel_minor  :
  scale_type == 4  ? scale_dorian     :
  scale_type == 5  ? scale_phrygian   :
  scale_type == 6  ? scale_lydian     :
  scale_type == 7  ? scale_mixolydian :
  scale_type == 8  ? scale_locrian    :
  scale_type == 9  ? scale_pent_maj   :
  scale_type == 10 ? scale_pent_min   :
  scale_blues;
);

function get_scale_length(scale_type) (
  scale_type == 9 || scale_type == 10 ? 5 :
  scale_type == 11 ? 6 :
  7;
);

function generate_pattern() local(i, scale_ptr, scale_len, steps_total, note_idx, octave, velocity_var, duration_var, should_trigger, step_dur) (
  scale_ptr   = get_scale(slider2);
  scale_len   = get_scale_length(slider2);
  steps_total = slider9 * slider10;
  i = 0;
  loop(steps_total,
    should_trigger = (rand() * 100) < slider4;
    pattern_buffer[i * 4] = should_trigger;
    should_trigger ? (
      note_idx = floor(rand() * scale_len);
      octave   = floor(rand() * slider11);
      pattern_buffer[i * 4 + 1] = max(0, min(127, slider1 + scale_ptr[note_idx] + octave * 12));
      velocity_var = (rand() - 0.5) * 2 * (slider6 / 100);
      pattern_buffer[i * 4 + 2] = max(1, min(127, floor(slider5 + slider5 * velocity_var)));
      duration_var = (rand() - 0.5) * 2 * (slider8 / 100);
      step_dur = step_length * (slider7 / 100) * (1 + duration_var);
      pattern_buffer[i * 4 + 3] = max(srate * 0.01, min(step_length * 0.95, step_dur));
    ) : (
      pattern_buffer[i * 4 + 1] = 0;
      pattern_buffer[i * 4 + 2] = 0;
      pattern_buffer[i * 4 + 3] = 0;
    );
    i += 1;
  );
);

// ── GUI helper functions ──────────────────────────────────────────────────

function draw_sec_hdr(sy, hr, hg, hb, title) local(tw, th) (
  gfx_r=hr; gfx_g=hg; gfx_b=hb; gfx_a=1;
  gfx_rect(GUI_SEC_X, sy, GUI_SEC_W, GUI_HDR_H);
  gfx_r=0.08; gfx_g=0.08; gfx_b=0.08; gfx_a=1;
  gfx_setfont(1, "Arial", 10, 'b');
  gfx_measurestr(title, tw, th);
  gfx_x = GUI_SEC_X + GUI_SEC_W/2 - tw/2;
  gfx_y = sy + GUI_HDR_H/2 - th/2;
  gfx_drawstr(title);
  gfx_r=0.28; gfx_g=0.28; gfx_b=0.32; gfx_a=1;
  gfx_rect(GUI_SEC_X, sy, GUI_SEC_W, 1);
  gfx_rect(GUI_SEC_X, sy + GUI_HDR_H, GUI_SEC_W, 1);
  sy + GUI_HDR_H;
);

function draw_hslider(sx, sy, sw, sh, val, lo, hi) local(norm, tx) (
  norm = max(0, min(1, (val - lo) / (hi - lo)));
  tx = sx + floor(norm * sw);
  gfx_r=0.06; gfx_g=0.06; gfx_b=0.08; gfx_a=1;
  gfx_rect(sx, sy + sh/2 - 4, sw, 8);
  gfx_r=0.85; gfx_g=0.60; gfx_b=0.10; gfx_a=1;
  gfx_rect(sx, sy + sh/2 - 4, floor(norm * sw), 8);
  gfx_r=0.35; gfx_g=0.35; gfx_b=0.40; gfx_a=1;
  gfx_rect(sx, sy + sh/2 - 4, sw, 1);
  gfx_rect(sx, sy + sh/2 + 3, sw, 1);
  gfx_rect(sx, sy + sh/2 - 4, 1, 8);
  gfx_rect(sx + sw, sy + sh/2 - 4, 1, 9);
  gfx_r=0.90; gfx_g=0.90; gfx_b=0.92; gfx_a=1;
  gfx_rect(tx - 5, sy + sh/2 - 9, 10, 18);
  gfx_r=0.25; gfx_g=0.25; gfx_b=0.28; gfx_a=1;
  gfx_rect(tx - 5, sy + sh/2 - 9, 10, 1);
  gfx_rect(tx - 5, sy + sh/2 + 8, 10, 1);
  gfx_rect(tx - 5, sy + sh/2 - 9, 1, 18);
  gfx_rect(tx + 4, sy + sh/2 - 9, 1, 18);
  gfx_r=0.50; gfx_g=0.50; gfx_b=0.54; gfx_a=1;
  gfx_rect(tx - 1, sy + sh/2 - 5, 2, 10);
);

function draw_row(sy, lbl, val_str) local(lw, lh) (
  gfx_r=0.12; gfx_g=0.12; gfx_b=0.14; gfx_a=1;
  gfx_rect(GUI_SEC_X, sy, GUI_SEC_W, GUI_ROW_H);
  gfx_r=0.20; gfx_g=0.20; gfx_b=0.22; gfx_a=1;
  gfx_rect(GUI_SEC_X, sy + GUI_ROW_H - 1, GUI_SEC_W, 1);
  gfx_r=0.92; gfx_g=0.92; gfx_b=0.94; gfx_a=1;
  gfx_setfont(1, "Arial", 10);
  gfx_measurestr(lbl, lw, lh);
  gfx_x = GUI_SEC_X + GUI_LBL_W - lw - 6;
  gfx_y = sy + GUI_ROW_H/2 - lh/2;
  gfx_drawstr(lbl);
  gfx_r=1.0; gfx_g=0.82; gfx_b=0.44; gfx_a=1;
  gfx_measurestr(val_str, lw, lh);
  gfx_x = GUI_VAL_X + GUI_VAL_W - lw - 4;
  gfx_y = sy + GUI_ROW_H/2 - lh/2;
  gfx_drawstr(val_str);
  sy + GUI_ROW_H;
);

function process_slider(sy, val, lo, hi) local(mx_rel, in_zone) (
  in_zone = (mouse_x >= GUI_SLD_X && mouse_x <= GUI_SLD_X + GUI_SLD_W &&
             mouse_y >= sy && mouse_y < sy + GUI_ROW_H);

  // Detect click down
  in_zone && mouse_btn && !last_mouse_btn ? (
    // Double-click: same row within threshold
    (last_click_row == row_idx && current_time - last_click_time < dbl_click_thresh) ? (
      val = defaults[row_idx];
      drag_slider = -1;
    ) : (
      drag_slider = row_idx;
    );
    last_click_time = current_time;
    last_click_row  = row_idx;
  );

  // Continue drag
  drag_slider == row_idx && mouse_btn ? (
    mx_rel = (mouse_x - GUI_SLD_X) / GUI_SLD_W;
    val = max(lo, min(hi, lo + mx_rel * (hi - lo)));
  );

  row_idx += 1;
  val;
);

@slider
current_tempo    = slider12 ? tempo : slider13;
current_tempo    = max(40, current_tempo);
samples_per_beat = srate * 60 / current_tempo;
step_length      = samples_per_beat / slider9;

@block

current_time += samplesblock;

current_tempo    = slider12 ? tempo : slider13;
current_tempo    = max(40, current_tempo);
samples_per_beat = srate * 60 / current_tempo;
step_length      = samples_per_beat / slider9;

// Runs always — triggers MIDI regardless of transport state
next_step_time <= 0 ? (
  next_step_time = current_time + step_length;
  generate_pattern();
);

pattern_just_reset ? (
  (rand() * 100) >= slider3 ? generate_pattern();
  pattern_just_reset = 0;
);

current_time >= next_step_time ? (
  steps_total = slider9 * slider10;
  trigger  = pattern_buffer[pattern_step * 4];
  note     = pattern_buffer[pattern_step * 4 + 1];
  velocity = pattern_buffer[pattern_step * 4 + 2];
  duration = pattern_buffer[pattern_step * 4 + 3];

  trigger && note > 0 ? (
    midisend(0, $x90, note, velocity);
    active_notes[note_count * 3]     = note;
    active_notes[note_count * 3 + 1] = velocity;
    active_notes[note_count * 3 + 2] = current_time + duration;
    note_count += 1;
  );

  pattern_step += 1;
  pattern_step >= steps_total ? (
    pattern_step       = 0;
    pattern_just_reset = 1;
  );
  next_step_time += step_length;
);

i = 0;
while (i < note_count) (
  active_notes[i * 3 + 2] <= current_time ? (
    midisend(0, $x80, active_notes[i * 3], 0);
    last = note_count - 1;
    active_notes[i * 3]     = active_notes[last * 3];
    active_notes[i * 3 + 1] = active_notes[last * 3 + 1];
    active_notes[i * 3 + 2] = active_notes[last * 3 + 2];
    note_count -= 1;
  ) : (
    i += 1;
  );
);

@gfx 620 530

GUI_PAD   = 8;
GUI_LBL_W = 160;
GUI_VAL_W = 68;
GUI_ROW_H = 28;
GUI_HDR_H = 22;
GUI_SEC_X = GUI_PAD;
GUI_SEC_W = gfx_w - GUI_PAD * 2;
GUI_SLD_W = GUI_SEC_W - GUI_LBL_W - GUI_VAL_W - GUI_PAD * 2;
GUI_SLD_X = GUI_SEC_X + GUI_LBL_W;
GUI_VAL_X = GUI_SLD_X + GUI_SLD_W + GUI_PAD;

gfx_r=0.14; gfx_g=0.14; gfx_b=0.16; gfx_a=1;
gfx_rect(0, 0, gfx_w, gfx_h);

gfx_r=0.78; gfx_g=0.78; gfx_b=0.82; gfx_a=1;
gfx_setfont(1, "Trebuchet MS", 14, 'b');
gfx_x=12; gfx_y=10; gfx_drawstr("PROBABILISTIC MIDI NOTE GENERATOR");
gfx_r=0.55; gfx_g=0.55; gfx_b=0.60; gfx_a=1;
gfx_setfont(1, "Trebuchet MS", 10);
gfx_x=430; gfx_y=13; gfx_drawstr("Generative Music Machine");

mouse_btn = mouse_cap & 1;
mouse_btn == 0 ? drag_slider = -1;
row_idx = 0;
cur_y = 32;

cur_y = draw_sec_hdr(cur_y, 0.18, 0.45, 0.82, "SCALE");
slider1 = process_slider(cur_y, slider1, 0, 127);
sprintf(#v, "%d", slider1);
cur_y = draw_row(cur_y, "Root Note", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider1, 0, 127);

slider2 = process_slider(cur_y, slider2, 0, 11);
  slider2 < 0.5 ? strcpy(#v, "Major") :
  slider2 < 1.5 ? strcpy(#v, "Nat Minor") :
  slider2 < 2.5 ? strcpy(#v, "Harm Minor") :
  slider2 < 3.5 ? strcpy(#v, "Mel Minor") :
  slider2 < 4.5 ? strcpy(#v, "Dorian") :
  slider2 < 5.5 ? strcpy(#v, "Phrygian") :
  slider2 < 6.5 ? strcpy(#v, "Lydian") :
  slider2 < 7.5 ? strcpy(#v, "Mixolydian") :
  slider2 < 8.5 ? strcpy(#v, "Locrian") :
  slider2 < 9.5 ? strcpy(#v, "Pent Maj") :
  slider2 < 10.5 ? strcpy(#v, "Pent Min") : strcpy(#v, "Blues");
cur_y = draw_row(cur_y, "Scale Type", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider2, 0, 11);

slider11 = process_slider(cur_y, slider11, 1, 4);
sprintf(#v, "%.0f oct", slider11);
cur_y = draw_row(cur_y, "Octave Range", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider11, 1, 4);

cur_y += 4;

cur_y = draw_sec_hdr(cur_y, 0.82, 0.18, 0.14, "PATTERN");
slider3 = process_slider(cur_y, slider3, 0, 100);
sprintf(#v, "%d%%", slider3);
cur_y = draw_row(cur_y, "Repeat Probability", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider3, 0, 100);

slider4 = process_slider(cur_y, slider4, 0, 100);
sprintf(#v, "%d%%", slider4);
cur_y = draw_row(cur_y, "Trigger Probability", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider4, 0, 100);

slider9 = process_slider(cur_y, slider9, 1, 16);
sprintf(#v, "%.0f", slider9);
cur_y = draw_row(cur_y, "Steps per Beat", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider9, 1, 16);

slider10 = process_slider(cur_y, slider10, 1, 8);
sprintf(#v, "%.0f beats", slider10);
cur_y = draw_row(cur_y, "Pattern Length", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider10, 1, 8);

cur_y += 4;

cur_y = draw_sec_hdr(cur_y, 0.16, 0.68, 0.28, "VELOCITY");
slider5 = process_slider(cur_y, slider5, 1, 127);
sprintf(#v, "%.0f", slider5);
cur_y = draw_row(cur_y, "Base Velocity", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider5, 1, 127);

slider6 = process_slider(cur_y, slider6, 0, 100);
sprintf(#v, "%d%%", slider6);
cur_y = draw_row(cur_y, "Velocity Randomness", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider6, 0, 100);

cur_y += 4;

cur_y = draw_sec_hdr(cur_y, 0.8, 0.55, 0.08, "TIMING");
slider7 = process_slider(cur_y, slider7, 10, 100);
sprintf(#v, "%d%% of step", slider7);
cur_y = draw_row(cur_y, "Note Duration", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider7, 10, 100);

slider8 = process_slider(cur_y, slider8, 0, 100);
sprintf(#v, "%d%%", slider8);
cur_y = draw_row(cur_y, "Duration Randomness", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider8, 0, 100);

slider12 = process_slider(cur_y, slider12, 0, 1);
slider12 < 0.5 ? strcpy(#v, "Internal") : strcpy(#v, "Project");
cur_y = draw_row(cur_y, "Tempo Sync", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider12, 0, 1);

slider13 = process_slider(cur_y, slider13, 40, 300);
sprintf(#v, "%.0f BPM", slider13);
cur_y = draw_row(cur_y, "Internal BPM", #v);
draw_hslider(GUI_SLD_X, cur_y - GUI_ROW_H, GUI_SLD_W, GUI_ROW_H, slider13, 40, 300);

cur_y += 4;

// Status bar
gfx_r=0.10; gfx_g=0.10; gfx_b=0.12; gfx_a=1;
gfx_rect(GUI_SEC_X, cur_y, GUI_SEC_W, GUI_ROW_H);
sprintf(#st, "Step %d / %d   Active notes: %d   Tempo: %.1f BPM",
  pattern_step + 1, slider9 * slider10, note_count, current_tempo);
gfx_r=1.0; gfx_g=0.82; gfx_b=0.44; gfx_a=1;
gfx_setfont(1, "Arial", 10);
gfx_x=GUI_SEC_X+8; gfx_y=cur_y + GUI_ROW_H/2 - 5;
gfx_drawstr(#st);
last_mouse_btn = mouse_btn;
