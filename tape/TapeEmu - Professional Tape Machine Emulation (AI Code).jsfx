desc: TapeEmu - Professional Tape Machine Emulation
version: 2.7
author: citizenkeith - Claude AI
about: Tape emulation that includes tape machine choices 
// Linux users can download the Trebuchet MS font at https://font.download/font/trebuchet-ms-2
// @version 2.7
// @author citizenkeith
// @license GPL v3
// @depends ../citizenkeith-ui-lib/citizenkeith-ui-lib.jsfx
// @changelog
//   v2.7
//     Precomputed LOG10_OVER_20 and LOG10_OVER_40 constants at @init — eliminates
//     repeated log() calls from update_audio_vars(), update_scalars(), and both
//     filter coefficient functions
//     Precomputed sat_amount and sat_norm in update_audio_vars()/update_scalars() —
//     eliminates per-sample sin() call; @sample now uses precomputed values only
//     Declared head_bump_db = 0 at @init — was previously an implicit global set as
//     a side-effect of calculate_head_bump_filter(), making @sample bypass check fragile
//     Removed LFM coefficient block from update_scalars() — coefficients recalculated
//     only in update_audio_vars() via @slider, consistent with the biquad/scalar split
//     Removed lfm_width, lfm_stereoLP, lfm_outL, lfm_outR dead code — lfm_width was
//     always 0.0; LFM output simplified to spl = lfm_monoLP + lfm_high
//     Stereo noise: noise_l and noise_r now generated independently per channel —
//     was mono (same value both channels), always appeared panned centre
//     update_scalars() now skips exp() calls when no relevant slider has changed —
//     cached slider values compared each frame; recompute only on actual change
//     Reduced wow/flutter delay buffer from 1024 to 512 samples — max read offset
//     is ~256 samples; 1024 was 4x larger than necessary
//   v2.6
//     Fixed random output spikes on all presets: split update_audio_vars() into
//     update_audio_vars() (filter coefficients, @slider only) and update_scalars()
//     (scalars only, @gfx) — eliminates race condition between GUI thread
//     recalculating biquad coefficients and audio thread mid-filter
//     Fixed left-channel spikes when enabling Wow & Flutter: wow/flutter
//     delay buffers were placed at address 0, overlapping the UI library
//     memory region; buffers now allocated after freemem from ui_setup()
//   v2.5
//     Title changed to "TAPEEMU" with "Tape Machine Emulation" subtitle
//     Tape Machine section height increased: 10px padding above and below buttons
//   v2.4
//     Added spacing between Tape Machine and lower sections
//   v2.3
//     Standardized section header colors: I/O=green, Stereo=blue
//     Fixed Noise and Head Bump not updating DSP when dragged (missing update_audio_vars() in @gfx)
//   v2.2
//     Fixed Noise and Head Bump not updating DSP when dragged (missing update_audio_vars() in @gfx)
//     Fixed Noise slider: now scales noise for all tape machine presets (was Basic Tape only)
//     Fixed Head Bump slider: now trims preset head bump value (was Basic Tape only)
//   v2.1
//     Section boxes (I/O, Noise & Head Bump, Character) matching citizenkeith plugin family
//     Knob order: Stereo Width and Wow & Flutter swapped in Character section
//     Background and title styling updated to match Watkins/CocteauVerb
//     Removed GUI meters — using REAPER default meter
//     Added double-click to reset knobs, amber value readouts
//   v2.0
//     Complete GUI overhaul with machine selector buttons
//     Added double-click to reset knobs to default values
//     Fixed head bump implementation (low shelf @ 90Hz)
//     Fixed Ampex ATR102 gain staging (was 1.7dB hot)
//     Added machine-specific high-frequency rolloff
//     Unity gain by default (0% input, 0dB output)
//     Conditional dimming of Noise and Head Bump knobs when presets active
//     5 tape machine models: Studer A800, Ampex ATR102, Sony APR5000, Otari MTR90, Basic Tape
options:

// Import UI library
import citizenkeith-ui-lib.jsfx-inc

slider1:0<0,178,1>-Input/Saturation (%)
slider2:0<-50,0,1>-Output (dB)
slider3:0<0,100,1>-Noise (%)
slider4:0<0,18,0.1>-Head Bump (dB)
slider5:0<0,100,1>-Tape Age (%)
slider6:100<0,200,1>-Stereo Width (%)
slider7:4<0,4,1{Studer A800,Ampex ATR102,Sony APR5000,Otari MTR90,Basic Tape}>-Tape Machine
slider8:0<0,100,1>-Wow & Flutter (%)
slider9:0<0,100,1>-LF Mono (%)

in_pin:left input
in_pin:right input
out_pin:left output
out_pin:right output

@init
// Precomputed log constants
LOG10_OVER_20 = log(10) / 20;
LOG10_OVER_40 = log(10) / 40;

// Cached slider values for update_scalars() dirty check
sc_s1 = sc_s2 = sc_s3 = sc_s5 = sc_s6 = sc_s7 = sc_s8 = -99999;

// Tape age and wow/flutter variables
age_dropout_counter = 0;
dropout_counter = 0;
age_noise_seed = 12345;

// Wow and flutter variables
wow_phase = 0;
flutter_phase = 0;
wf_write_pos = 0;
wf_buffer_size = 512;

// Zero wow/flutter delay buffers to prevent garbage reads on first enable
memset(wf_buffer_l, 0, wf_buffer_size);
memset(wf_buffer_r, 0, wf_buffer_size);

// Head bump filter variables
head_bump_db = 0;
hb_b0 = hb_b1 = hb_b2 = 0;
hb_a1 = hb_a2 = 0;
hb_x1_l = hb_x2_l = hb_y1_l = hb_y2_l = 0;
hb_x1_r = hb_x2_r = hb_y1_r = hb_y2_r = 0;

// High-frequency rolloff filter variables
hf_b0 = hf_b1 = hf_b2 = 0;
hf_a1 = hf_a2 = 0;
hf_x1_l = hf_x2_l = hf_y1_l = hf_y2_l = 0;
hf_x1_r = hf_x2_r = hf_y1_r = hf_y2_r = 0;

// Tape machine preset variables
preset_head_bump = 0;
preset_sat_character = 1.0;
preset_noise_floor = -105;
preset_output_compensation = 1.0;
preset_hf_rolloff_freq = 20000;
preset_hf_rolloff_amount = 0;

// UI setup
ext_noinit = 1;
freemem = ui_setup(0);

// Wow and flutter delay buffers — placed after UI library memory to avoid corruption
wf_buffer_l = freemem;
wf_buffer_r = freemem + 512;
freemem += 1024;

// ============================================================
// GFX HELPER FUNCTIONS
// ============================================================

function draw_section_box(bx, by, bw, bh, hr, hg, hb, header_text)
local(tw, th, hdr_h)
(
  hdr_h = 22;
  gfx_r=0.12; gfx_g=0.12; gfx_b=0.14; gfx_a=1;
  gfx_rect(bx, by, bw, bh);
  gfx_r=hr; gfx_g=hg; gfx_b=hb; gfx_a=1;
  gfx_rect(bx, by, bw, hdr_h);
  gfx_r=0.08; gfx_g=0.08; gfx_b=0.08; gfx_a=1;
  gfx_setfont(1, "Arial", 11, 'b');
  gfx_measurestr(header_text, tw, th);
  gfx_x = bx + 8;
  gfx_y = by + hdr_h/2 - th/2;
  gfx_drawstr(header_text);
  gfx_r=0.28; gfx_g=0.28; gfx_b=0.32; gfx_a=1;
  gfx_rect(bx,      by,      bw, 1);
  gfx_rect(bx,      by+bh-1, bw, 1);
  gfx_rect(bx,      by,      1,  bh);
  gfx_rect(bx+bw-1, by,      1,  bh+1);
);

function draw_knob_label(lx, ly)
local(lw, lh)
(
  gfx_r=0.71; gfx_g=0.71; gfx_b=0.75; gfx_a=1;
  gfx_setfont(1, "Arial", 10);
  gfx_measurestr(#lbl, lw, lh);
  gfx_x = lx - lw/2;
  gfx_y = ly;
  gfx_drawstr(#lbl);
);

dbl_click_time = 0;
dbl_click_x = dbl_click_y = -1;

function check_dbl_click()
(
  mouse_cap & 1 && !(mouse_cap_last & 1) ? (
    this_click_time = time_precise();
    this_click_time - dbl_click_time < 0.4 ? (
      dbl_clicked = 1;
    ) : (
      dbl_clicked = 0;
    );
    dbl_click_time = this_click_time;
    dbl_click_x = mouse_x;
    dbl_click_y = mouse_y;
  ) : (
    dbl_clicked = 0;
  );
  mouse_cap_last = mouse_cap;
);

function dbl_click_in_rect(rx, ry, rw, rh)
(
  dbl_clicked &&
  dbl_click_x >= rx && dbl_click_x < rx+rw &&
  dbl_click_y >= ry && dbl_click_y < ry+rh;
);

// Function to load tape machine presets
function load_tape_preset(preset_num) (
  preset_num == 0 ? ( // Studer A800
    preset_head_bump = 6;
    preset_sat_character = 0.8;
    preset_noise_floor = -95;
    preset_output_compensation = 1.0;
    preset_hf_rolloff_freq = 15000;
    preset_hf_rolloff_amount = -3;
  ) : preset_num == 1 ? ( // Ampex ATR102
    preset_head_bump = 8;
    preset_sat_character = 1.2;
    preset_noise_floor = -90;
    preset_output_compensation = 0.823;
    preset_hf_rolloff_freq = 12000;
    preset_hf_rolloff_amount = -4;
  ) : preset_num == 2 ? ( // Sony APR5000
    preset_head_bump = 4;
    preset_sat_character = 0.6;
    preset_noise_floor = -98;
    preset_output_compensation = 1.0;
    preset_hf_rolloff_freq = 18000;
    preset_hf_rolloff_amount = -1.5;
  ) : preset_num == 3 ? ( // Otari MTR90
    preset_head_bump = 5;
    preset_sat_character = 0.9;
    preset_noise_floor = -96;
    preset_output_compensation = 1.0;
    preset_hf_rolloff_freq = 14000;
    preset_hf_rolloff_amount = -2.5;
  ) : ( // Basic Tape
    preset_head_bump = slider4;
    preset_sat_character = 1.0;
    preset_noise_floor = -105;  // unused in Basic Tape mode; noise_db derived from slider3 in update_audio_vars
    preset_output_compensation = 1.0;
    preset_hf_rolloff_freq = 20000;
    preset_hf_rolloff_amount = 0;
  );
);

function calculate_head_bump_filter() local(A, w0, cosw0, sinw0, alpha, beta, a0) (
  head_bump_db = (slider7 == 4 ? slider4 : preset_head_bump);
  
  head_bump_db > 0 ? (
    A = exp(head_bump_db * LOG10_OVER_40);
    w0 = 2 * $pi * 90 / srate;
    cosw0 = cos(w0);
    sinw0 = sin(w0);
    alpha = sinw0 / (2 * 0.707);
    beta = sqrt(A) / 0.707;
    
    hb_b0 = A * ((A + 1) - (A - 1) * cosw0 + beta * sinw0);
    hb_b1 = 2 * A * ((A - 1) - (A + 1) * cosw0);
    hb_b2 = A * ((A + 1) - (A - 1) * cosw0 - beta * sinw0);
    a0 = (A + 1) + (A - 1) * cosw0 + beta * sinw0;
    hb_a1 = -2 * ((A - 1) + (A + 1) * cosw0);
    hb_a2 = (A + 1) + (A - 1) * cosw0 - beta * sinw0;
    
    hb_b0 /= a0;
    hb_b1 /= a0;
    hb_b2 /= a0;
    hb_a1 /= a0;
    hb_a2 /= a0;
  ) : (
    hb_b0 = 1;
    hb_b1 = 0;
    hb_b2 = 0;
    hb_a1 = 0;
    hb_a2 = 0;
  );
);

function calculate_hf_rolloff_filter() local(A, w0, cosw0, sinw0, alpha, beta, a0) (
  preset_hf_rolloff_amount < 0 ? (
    A = exp(preset_hf_rolloff_amount * LOG10_OVER_40);
    w0 = 2 * $pi * preset_hf_rolloff_freq / srate;
    cosw0 = cos(w0);
    sinw0 = sin(w0);
    alpha = sinw0 / (2 * 0.707);
    beta = sqrt(A) / 0.707;
    
    hf_b0 = A * ((A + 1) + (A - 1) * cosw0 + beta * sinw0);
    hf_b1 = -2 * A * ((A - 1) + (A + 1) * cosw0);
    hf_b2 = A * ((A + 1) + (A - 1) * cosw0 - beta * sinw0);
    a0 = (A + 1) - (A - 1) * cosw0 + beta * sinw0;
    hf_a1 = 2 * ((A - 1) - (A + 1) * cosw0);
    hf_a2 = (A + 1) - (A - 1) * cosw0 - beta * sinw0;
    
    hf_b0 /= a0;
    hf_b1 /= a0;
    hf_b2 /= a0;
    hf_a1 /= a0;
    hf_a2 /= a0;
  ) : (
    hf_b0 = 1;
    hf_b1 = 0;
    hf_b2 = 0;
    hf_a1 = 0;
    hf_a2 = 0;
  );
);

function update_audio_vars() (
  load_tape_preset(slider7);
  output_gain = exp(slider2 * LOG10_OVER_20) * preset_output_compensation;
  age_factor = 1 + (slider5 / 100) * 3;
  noise_db   = (slider7 == 4) ? (-105 + slider3 * 0.45) : preset_noise_floor;
  noise_base = (slider7 == 4 && slider3 == 0) ? 0 : exp(noise_db * LOG10_OVER_20);
  noise_gain = noise_base * age_factor;
  width_factor = slider6 / 100;
  wow_flutter_amount = slider8 / 100;
  effective_saturation = slider1 * preset_sat_character;
  sat_amount = (effective_saturation / 200) * $pi;
  sat_norm   = (effective_saturation > 0) ? sin(sat_amount) : 1;
  calculate_head_bump_filter();
  calculate_hf_rolloff_filter();
  // LF Mono crossover (1-pole, 0-100% → 0-300 Hz)
  // At slider9 == 0: a0=0, b1=0 → filter outputs 0 → spl passes through unchanged
  lfm_fc = slider9 * 3.0;
  slider9 > 0 ? (
    lfm_x  = exp(-2.0 * $pi * lfm_fc / srate);
    lfm_a0 = 1.0 - lfm_x;
    lfm_b1 = -lfm_x;
  ) : (
    lfm_a0 = 0; lfm_b1 = 0;
  );
);

// Scalar-only update — safe to call from @gfx every frame (no filter coefficient recalculation)
// LFM coefficients intentionally excluded — updated via update_audio_vars() on @slider only
function update_scalars() (
  (slider1 != sc_s1 || slider2 != sc_s2 || slider3 != sc_s3 ||
   slider5 != sc_s5 || slider6 != sc_s6 || slider7 != sc_s7 || slider8 != sc_s8) ? (
    load_tape_preset(slider7);
    output_gain = exp(slider2 * LOG10_OVER_20) * preset_output_compensation;
    age_factor = 1 + (slider5 / 100) * 3;
    noise_db   = (slider7 == 4) ? (-105 + slider3 * 0.45) : preset_noise_floor;
    noise_base = (slider7 == 4 && slider3 == 0) ? 0 : exp(noise_db * LOG10_OVER_20);
    noise_gain = noise_base * age_factor;
    width_factor = slider6 / 100;
    wow_flutter_amount = slider8 / 100;
    effective_saturation = slider1 * preset_sat_character;
    sat_amount = (effective_saturation / 200) * $pi;
    sat_norm   = (effective_saturation > 0) ? sin(sat_amount) : 1;
    sc_s1 = slider1; sc_s2 = slider2; sc_s3 = slider3;
    sc_s5 = slider5; sc_s6 = slider6; sc_s7 = slider7; sc_s8 = slider8;
  );
);

// LF Mono filter state
lfm_tmpl = lfm_tmpr = 0;
lfm_a0 = lfm_b1 = 0;

update_audio_vars();

@slider
update_audio_vars();

@sample
effective_saturation > 0 ? (
  slider7 == 0 ? (
    spl0 = min(max(sin(max(min(spl0, 1), -1) * sat_amount) / sat_norm + spl0 * spl0 * 0.1, -1), 1);
    spl1 = min(max(sin(max(min(spl1, 1), -1) * sat_amount) / sat_norm + spl1 * spl1 * 0.1, -1), 1);
  ) : slider7 == 1 ? (
    spl0 = min(max(sin(max(min(spl0, 1), -1) * sat_amount) / sat_norm + spl0 * spl0 * spl0 * 0.15, -1), 1);
    spl1 = min(max(sin(max(min(spl1, 1), -1) * sat_amount) / sat_norm + spl1 * spl1 * spl1 * 0.15, -1), 1);
  ) : slider7 == 2 ? (
    spl0 = min(max(sin(max(min(spl0, 1), -1) * sat_amount) / sat_norm + spl0 * spl0 * 0.05, -1), 1);
    spl1 = min(max(sin(max(min(spl1, 1), -1) * sat_amount) / sat_norm + spl1 * spl1 * 0.05, -1), 1);
  ) : slider7 == 3 ? (
    spl0 = min(max(sin(max(min(spl0, 1), -1) * sat_amount) / sat_norm + spl0 * spl0 * 0.08 + spl0 * spl0 * spl0 * 0.05, -1), 1);
    spl1 = min(max(sin(max(min(spl1, 1), -1) * sat_amount) / sat_norm + spl1 * spl1 * 0.08 + spl1 * spl1 * spl1 * 0.05, -1), 1);
  ) : (
    spl0 = min(max(sin(max(min(spl0, 1), -1) * sat_amount) / sat_norm, -1), 1);
    spl1 = min(max(sin(max(min(spl1, 1), -1) * sat_amount) / sat_norm, -1), 1);
  );
);

noise_l = rand(2) - 1;
noise_r = rand(2) - 1;

slider7 == 0 ? (
  noise_l = noise_l * 0.8 + sin(noise_l * $pi) * 0.2;
  noise_r = noise_r * 0.8 + sin(noise_r * $pi) * 0.2;
) : slider7 == 1 ? (
  noise_l = noise_l + noise_l * noise_l * noise_l * 0.3;
  noise_r = noise_r + noise_r * noise_r * noise_r * 0.3;
) : slider7 == 3 ? (
  noise_l = noise_l * 0.9 + sin(noise_l * $pi * 0.5) * 0.1;
  noise_r = noise_r * 0.9 + sin(noise_r * $pi * 0.5) * 0.1;
);

slider5 > 0 ? (
  age_dropout_counter += 1;
  age_dropout_counter > srate / 20 ? (
    age_dropout_counter = 0;
    dropout_chance = slider5 / 100 * 0.01;
    rand() < dropout_chance ? (
      dropout_length = floor(rand() * srate * 0.05);
      dropout_counter = dropout_length;
    );
  );
  
  dropout_counter > 0 ? (
    dropout_factor = 0.05 + rand() * 0.2;
    spl0 *= dropout_factor;
    spl1 *= dropout_factor;
    dropout_counter -= 1;
  );
  
  age_mod = sin(age_noise_seed * 0.01) * slider5 / 100 * 0.001;
  age_noise_seed += 1;
  noise_l += age_mod;
  noise_r += age_mod;
);

wow_flutter_amount > 0 ? (
  wf_buffer_l[wf_write_pos] = spl0;
  wf_buffer_r[wf_write_pos] = spl1;
  
  wow_phase += 0.5 / srate;
  wow_phase >= 1 ? wow_phase -= 1;
  
  flutter_phase += 12 / srate;
  flutter_phase >= 1 ? flutter_phase -= 1;
  
  wow_mod = sin(2 * $pi * wow_phase);
  flutter_mod = sin(2 * $pi * flutter_phase);
  total_modulation = wow_flutter_amount * (wow_mod * 0.0001 + flutter_mod * 0.00005);
  
  base_delay = 256;
  read_offset = base_delay * (1 + total_modulation);
  read_pos = wf_write_pos - read_offset;
  read_pos < 0 ? read_pos += wf_buffer_size;
  
  read_pos_int = floor(read_pos);
  read_pos_frac = read_pos - read_pos_int;
  read_pos_next = (read_pos_int + 1) % wf_buffer_size;
  
  spl0 = wf_buffer_l[read_pos_int] * (1 - read_pos_frac) + wf_buffer_l[read_pos_next] * read_pos_frac;
  spl1 = wf_buffer_r[read_pos_int] * (1 - read_pos_frac) + wf_buffer_r[read_pos_next] * read_pos_frac;
  
  wf_write_pos = (wf_write_pos + 1) % wf_buffer_size;
);

spl0 = spl0 * output_gain + noise_l * noise_gain;
spl1 = spl1 * output_gain + noise_r * noise_gain;

head_bump_db > 0 ? (
  hb_out_l = hb_b0 * spl0 + hb_b1 * hb_x1_l + hb_b2 * hb_x2_l - hb_a1 * hb_y1_l - hb_a2 * hb_y2_l;
  hb_x2_l = hb_x1_l;
  hb_x1_l = spl0;
  hb_y2_l = hb_y1_l;
  hb_y1_l = hb_out_l;
  spl0 = hb_out_l;
  
  hb_out_r = hb_b0 * spl1 + hb_b1 * hb_x1_r + hb_b2 * hb_x2_r - hb_a1 * hb_y1_r - hb_a2 * hb_y2_r;
  hb_x2_r = hb_x1_r;
  hb_x1_r = spl1;
  hb_y2_r = hb_y1_r;
  hb_y1_r = hb_out_r;
  spl1 = hb_out_r;
);

preset_hf_rolloff_amount < 0 ? (
  hf_out_l = hf_b0 * spl0 + hf_b1 * hf_x1_l + hf_b2 * hf_x2_l - hf_a1 * hf_y1_l - hf_a2 * hf_y2_l;
  hf_x2_l = hf_x1_l;
  hf_x1_l = spl0;
  hf_y2_l = hf_y1_l;
  hf_y1_l = hf_out_l;
  spl0 = hf_out_l;
  
  hf_out_r = hf_b0 * spl1 + hf_b1 * hf_x1_r + hf_b2 * hf_x2_r - hf_a1 * hf_y1_r - hf_a2 * hf_y2_r;
  hf_x2_r = hf_x1_r;
  hf_x1_r = spl1;
  hf_y2_r = hf_y1_r;
  hf_y1_r = hf_out_r;
  spl1 = hf_out_r;
);

mid = (spl0 + spl1) * 0.5;
side = (spl0 - spl1) * 0.5;
side *= width_factor;

slider7 == 0 ? (
  mid *= 1.02;
  side *= 0.98;
) : slider7 == 1 ? (
  mid = mid + mid * mid * 0.01;
  side *= 1.05;
) : slider7 == 3 ? (
  mid *= 1.01;
);

spl0 = mid + side;
spl1 = mid - side;

// ---- LF Mono summing (1-pole crossover, Fidelio-style) ----
lfm_lowL  = (lfm_tmpl = lfm_a0*spl0 - lfm_b1*lfm_tmpl);
lfm_lowR  = (lfm_tmpr = lfm_a0*spl1 - lfm_b1*lfm_tmpr);
lfm_highL = spl0 - lfm_lowL;
lfm_highR = spl1 - lfm_lowR;
lfm_monoLP = (lfm_lowL + lfm_lowR) * 0.5;
spl0 = lfm_monoLP + lfm_highL;
spl1 = lfm_monoLP + lfm_highR;

@gfx 650 262

control_start("main", "tron");

ui_screen() == "main" ? (

// ---- Background ----
gfx_r=0.14; gfx_g=0.14; gfx_b=0.16; gfx_a=1;
gfx_rect(0, 0, gfx_w, gfx_h);

// ---- Plugin title ----
gfx_r=0.78; gfx_g=0.78; gfx_b=0.82; gfx_a=1;
gfx_setfont(1, "Trebuchet MS", 14, 'b');
gfx_x=12; gfx_y=8;
gfx_drawstr("TAPEEMU");
gfx_r=1.0; gfx_g=1.0; gfx_b=1.0; gfx_a=1;
gfx_setfont(1, "Trebuchet MS", 10);
gfx_x=116; gfx_y=11;
gfx_drawstr("Tape Machine Emulation");

check_dbl_click();

// ============================================================
// LAYOUT CONSTANTS
// Window: 650 wide, 234 tall. Content x=8..642 (w=634)
//
// Tape Machine section:  y=34, h=64  (header 22 + pad 2 + buttons 36 + pad 4)
// Section row:           y=106, h=120
//   I/O:       x=8,   w=168  (2 knobs)
//   ARTIFACTS: x=184, w=268  (4 knobs: Noise, Head Bump, Tape Age, Wow & Flutter)
//   STEREO:    x=460, w=182  (2 knobs: Stereo Width, LF Mono)
// knob_cy: 106 + 22(hdr) + 16(gap) + 22(radius) = 166
// ============================================================

sect_y   = 120;
sect_h   = 132;
knob_cy  = 197;

// Knob centers — I/O
io_cx1 = 50;   // Input
io_cx2 = 134;  // Output

// Knob centers — ARTIFACTS (4 cols in 268px = 67px each)
af_cx1 = 218;  // Noise
af_cx2 = 285;  // Head Bump
af_cx3 = 352;  // Tape Age
af_cx4 = 419;  // Wow & Flutter

// Knob centers — STEREO (2 cols in 182px = 91px each)
st_cx1 = 505;  // Stereo Width
st_cx2 = 596;  // LF Mono

// ============================================================
// TAPE MACHINE SECTION  y=34, h=64
// ============================================================

// Section box (red header like Watkins)
draw_section_box(8, 34, 634, 78, 0.82, 0.22, 0.14, "TAPE MACHINE");

// 5 buttons inside section, below the 22px header + 10px padding
// x=12..638, each button ~125px wide
btn_y = 66; btn_h = 36;
i = 0;
loop(5,
  bx = 12 + i * 125;
  cur_bw = (i == 4) ? (638 - bx) : 124;
  machine_val = i == 0 ? 4 : i == 1 ? 0 : i == 2 ? 1 : i == 3 ? 2 : 3;
  is_sel = (slider7 == machine_val);

  ui_push_rect(bx, btn_y, cur_bw, btn_h);
    is_sel ? control_background_inset() : control_background_enabled("none");
    is_sel ? (
      ui_color(0, 255, 0);
      ui_push();
        ui_align(0.5, 0.2);
        ui_push_height(6);
          ui_push_width(6);
            ui_fill();
          ui_pop();
        ui_pop();
      ui_pop();
    );
    ui_color(255, 255, 255);
    ui_align(0.5, 0.6);
    ui_fontsize(10);
    i == 0 ? ui_text("BASIC TAPE") :
    i == 1 ? ui_text("STUDER A800") :
    i == 2 ? ui_text("AMPEX ATR102") :
    i == 3 ? ui_text("SONY APR5000") :
             ui_text("OTARI MTR90");
    is_sel ? control_finish_inset() : control_finish_enabled("none");
    ui_click() ? (
      slider7 = machine_val;
      sliderchange(slider7);
      update_audio_vars();
    );
  ui_pop();
  i += 1;
);

// ============================================================
// SECTION 1: I/O
// ============================================================
draw_section_box(8, sect_y, 168, sect_h, 0.22, 0.72, 0.32, "I/O");

ui_push_rect(io_cx1-22, knob_cy-22, 44, 44);
  ui_automate(slider1, control_dial(slider1, 0, 178, 0, 0));
ui_pop();
dbl_click_in_rect(io_cx1-22, knob_cy-22, 44, 44) ? (slider1 = 0; slider_automate(slider1); update_audio_vars(););
strcpy(#lbl, "INPUT"); draw_knob_label(io_cx1, knob_cy-36);
gfx_r=1.0; gfx_g=0.82; gfx_b=0.44; gfx_a=1; gfx_setfont(1, "Arial", 9);
sprintf(#val, "%d%%", slider1);
gfx_measurestr(#val, tw, th); gfx_x=io_cx1-tw/2; gfx_y=knob_cy+25; gfx_drawstr(#val);

ui_push_rect(io_cx2-22, knob_cy-22, 44, 44);
  ui_automate(slider2, control_dial(slider2, -50, 0, 0, 0));
ui_pop();
dbl_click_in_rect(io_cx2-22, knob_cy-22, 44, 44) ? (slider2 = 0; slider_automate(slider2); update_audio_vars(););
strcpy(#lbl, "OUTPUT"); draw_knob_label(io_cx2, knob_cy-36);
gfx_r=1.0; gfx_g=0.82; gfx_b=0.44; gfx_a=1; gfx_setfont(1, "Arial", 9);
sprintf(#val, "%d dB", slider2);
gfx_measurestr(#val, tw, th); gfx_x=io_cx2-tw/2; gfx_y=knob_cy+25; gfx_drawstr(#val);

// ============================================================
// SECTION 2: ARTIFACTS
// ============================================================
draw_section_box(184, sect_y, 268, sect_h, 0.80, 0.58, 0.08, "ARTIFACTS");

// NOISE (dimmed if preset active)
ui_push_rect(af_cx1-22, knob_cy-22, 44, 44);
  slider7 != 4 ? (
    ui_color(128, 128, 128, 0.5);
    control_dial(50, 0, 100, 0, 0);
  ) : (
    ui_automate(slider3, control_dial(slider3, 0, 100, 0, 0));
  );
ui_pop();
dbl_click_in_rect(af_cx1-22, knob_cy-22, 44, 44) ? (slider7 == 4 ? (slider3 = 0; slider_automate(slider3); update_audio_vars();););
slider7 != 4 ? (gfx_r=0.50; gfx_g=0.50; gfx_b=0.55;) : (gfx_r=0.71; gfx_g=0.71; gfx_b=0.75;);
gfx_a=1; gfx_setfont(1, "Arial", 10);
strcpy(#lbl, "NOISE"); gfx_measurestr(#lbl, lw, lh); gfx_x=af_cx1-lw/2; gfx_y=knob_cy-36; gfx_drawstr(#lbl);
gfx_r=1.0; gfx_g=0.82; gfx_b=0.44; gfx_a= slider7 != 4 ? 0.4 : 1.0; gfx_setfont(1, "Arial", 9);
(slider7 != 4) ? sprintf(#val, "%.0f dB", preset_noise_floor) :
(slider3 == 0) ? sprintf(#val, "OFF") :
                 sprintf(#val, "%.0f dB", -105 + slider3 * 0.45);
gfx_measurestr(#val, tw, th); gfx_x=af_cx1-tw/2; gfx_y=knob_cy+25; gfx_drawstr(#val);

// HEAD BUMP (dimmed if preset active)
ui_push_rect(af_cx2-22, knob_cy-22, 44, 44);
  slider7 != 4 ? (
    ui_color(128, 128, 128, 0.5);
    control_dial(preset_head_bump, 0, 18, 0, 0);
  ) : (
    ui_automate(slider4, control_dial(slider4, 0, 18, 0, 0));
  );
ui_pop();
dbl_click_in_rect(af_cx2-22, knob_cy-22, 44, 44) ? (slider7 == 4 ? (slider4 = 0; slider_automate(slider4); update_audio_vars();););
slider7 != 4 ? (gfx_r=0.50; gfx_g=0.50; gfx_b=0.55;) : (gfx_r=0.71; gfx_g=0.71; gfx_b=0.75;);
gfx_a=1; gfx_setfont(1, "Arial", 10);
strcpy(#lbl, "HEAD BUMP"); gfx_measurestr(#lbl, lw, lh); gfx_x=af_cx2-lw/2; gfx_y=knob_cy-36; gfx_drawstr(#lbl);
gfx_r=1.0; gfx_g=0.82; gfx_b=0.44; gfx_a= slider7 != 4 ? 0.4 : 1.0; gfx_setfont(1, "Arial", 9);
sprintf(#val, "%.1f dB", (slider7 != 4 ? preset_head_bump : slider4));
gfx_measurestr(#val, tw, th); gfx_x=af_cx2-tw/2; gfx_y=knob_cy+25; gfx_drawstr(#val);

// TAPE AGE
ui_push_rect(af_cx3-22, knob_cy-22, 44, 44);
  ui_automate(slider5, control_dial(slider5, 0, 100, 0, 0));
ui_pop();
dbl_click_in_rect(af_cx3-22, knob_cy-22, 44, 44) ? (slider5 = 0; slider_automate(slider5); update_audio_vars(););
strcpy(#lbl, "TAPE AGE"); draw_knob_label(af_cx3, knob_cy-36);
gfx_r=1.0; gfx_g=0.82; gfx_b=0.44; gfx_a=1; gfx_setfont(1, "Arial", 9);
sprintf(#val, "%d%%", slider5);
gfx_measurestr(#val, tw, th); gfx_x=af_cx3-tw/2; gfx_y=knob_cy+25; gfx_drawstr(#val);

// WOW & FLUTTER
ui_push_rect(af_cx4-22, knob_cy-22, 44, 44);
  ui_automate(slider8, control_dial(slider8, 0, 100, 0, 0));
ui_pop();
dbl_click_in_rect(af_cx4-22, knob_cy-22, 44, 44) ? (slider8 = 0; slider_automate(slider8); update_audio_vars(););
strcpy(#lbl, "W&F"); draw_knob_label(af_cx4, knob_cy-36);
gfx_r=1.0; gfx_g=0.82; gfx_b=0.44; gfx_a=1; gfx_setfont(1, "Arial", 9);
sprintf(#val, "%d%%", slider8);
gfx_measurestr(#val, tw, th); gfx_x=af_cx4-tw/2; gfx_y=knob_cy+25; gfx_drawstr(#val);

// ============================================================
// SECTION 3: STEREO
// ============================================================
draw_section_box(460, sect_y, 182, sect_h, 0.12, 0.62, 0.88, "STEREO");

// STEREO WIDTH
ui_push_rect(st_cx1-22, knob_cy-22, 44, 44);
  ui_automate(slider6, control_dial(slider6, 0, 200, 0, 100));
ui_pop();
dbl_click_in_rect(st_cx1-22, knob_cy-22, 44, 44) ? (slider6 = 100; slider_automate(slider6); update_audio_vars(););
strcpy(#lbl, "WIDTH"); draw_knob_label(st_cx1, knob_cy-36);
gfx_r=1.0; gfx_g=0.82; gfx_b=0.44; gfx_a=1; gfx_setfont(1, "Arial", 9);
sprintf(#val, "%d%%", slider6);
gfx_measurestr(#val, tw, th); gfx_x=st_cx1-tw/2; gfx_y=knob_cy+25; gfx_drawstr(#val);

// LF MONO (dummy — DSP TBD)
ui_push_rect(st_cx2-22, knob_cy-22, 44, 44);
  ui_automate(slider9, control_dial(slider9, 0, 100, 0, 0));
ui_pop();
dbl_click_in_rect(st_cx2-22, knob_cy-22, 44, 44) ? (slider9 = 0; slider_automate(slider9); update_audio_vars(););
strcpy(#lbl, "LF MONO"); draw_knob_label(st_cx2, knob_cy-36);
gfx_r=1.0; gfx_g=0.82; gfx_b=0.44; gfx_a=1; gfx_setfont(1, "Arial", 9);
slider9 > 0 ? sprintf(#val, "%d Hz", slider9*3) : sprintf(#val, "OFF");
gfx_measurestr(#val, tw, th); gfx_x=st_cx2-tw/2; gfx_y=knob_cy+25; gfx_drawstr(#val);

// Ensure DSP params update every frame when knobs are dragged
update_scalars();

) : ui_system();